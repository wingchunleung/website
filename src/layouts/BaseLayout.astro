---
import '../styles/global.css';
import '@fontsource-variable/inter';
import '@fontsource-variable/cormorant-garamond';
import '@fontsource-variable/jetbrains-mono';
import LockScreen from '../components/LockScreen.astro';

interface Props {
  title: string;
  description?: string;
  accent?: 'vermillion' | 'celadon';
}

const {
  title,
  description = 'Wing Chun Leung — finance, capital markets, and technology. MSc AI at HKUST, formerly Carta & Costco.',
  accent = 'vermillion',
} = Astro.props;

const accentColor = accent === 'celadon' ? '#7d9e8c' : '#c73e1d';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/og-image.svg`} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fonts: self-hosted via fontsource (no external DNS, GDPR-safe, faster) -->

    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
    <title>{title}</title>
    <!-- View transitions handled by CSS page load animation -->

    <!-- Structured data for SEO -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Wing Chun Leung",
      "jobTitle": "MSc AI · Research Assistant, AI in Asset Management",
      "affiliation": { "@type": "Organization", "name": "HKUST" },
      "url": "https://wingchunleung.github.io/website/",
      "sameAs": [
        "https://linkedin.com/in/wingchunleung",
        "https://github.com/wingchunleung"
      ],
      "knowsAbout": ["Artificial Intelligence", "Finance", "LLM", "Multi-Agent Systems"],
      "alumniOf": [
        { "@type": "EducationalOrganization", "name": "HKUST" },
        { "@type": "EducationalOrganization", "name": "University of Washington" }
      ]
    })} />

    <!-- Accent color override for HCI page -->
    {accent === 'celadon' && (
      <style is:inline>
        :root {
          --color-accent: #7d9e8c;
          --color-link-hover: #7d9e8c;
        }
      </style>
    )}
  </head>
  <body>
    <LockScreen />
    <a href="#main-content" class="skip-to-content">Skip to content</a>

    <slot name="header" />

    <main id="main-content">
      <slot />
    </main>

    <slot name="footer" />
  </body>
</html>
