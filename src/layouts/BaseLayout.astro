---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  accent?: 'vermillion' | 'celadon';
}

const {
  title,
  description = 'Wing Chun Leung — bridging finance and AI. MSc Artificial Intelligence at HKUST.',
  accent = 'vermillion',
} = Astro.props;

const accentColor = accent === 'celadon' ? '#7d9e8c' : '#c73e1d';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/og-image.svg`} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fonts: preconnect + load for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
    <title>{title}</title>

    <!-- Structured data for SEO -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Wing Chun Leung",
      "jobTitle": "MSc AI Student & Research Assistant",
      "affiliation": { "@type": "Organization", "name": "HKUST" },
      "url": "https://wingchunleung.github.io/website/",
      "sameAs": [
        "https://linkedin.com/in/wingchunleung",
        "https://github.com/wingchunleung"
      ],
      "knowsAbout": ["Artificial Intelligence", "Finance", "LLM", "Multi-Agent Systems"],
      "alumniOf": [
        { "@type": "EducationalOrganization", "name": "HKUST" },
        { "@type": "EducationalOrganization", "name": "University of Washington" }
      ]
    })} />

    <!-- Accent color override for HCI page -->
    {accent === 'celadon' && (
      <style is:inline>
        :root {
          --color-accent: #7d9e8c;
          --color-link-hover: #7d9e8c;
        }
      </style>
    )}
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Skip to content</a>

    <slot name="header" />

    <main id="main-content">
      <slot />
    </main>

    <slot name="footer" />
  </body>
</html>
