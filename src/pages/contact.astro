---
/**
 * Contact Page — Clean, premium, direct
 * HCI: H8 (Error Prevention) — clear, unambiguous contact paths
 * HCI: Fitts's Law — large, easy-to-tap contact cards
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const contacts = [
  {
    label: 'Email',
    value: 'wingchunleung8@gmail.com',
    href: 'mailto:wingchunleung8@gmail.com',
    cta: 'Send an email',
    external: false,
  },
  {
    label: 'LinkedIn',
    value: '/in/wingchunleung',
    href: 'https://linkedin.com/in/wingchunleung',
    cta: 'Connect',
    external: true,
  },
  {
    label: 'GitHub',
    value: 'wingchunleung',
    href: 'https://github.com/wingchunleung',
    cta: 'View code',
    external: true,
  },
];
---

<BaseLayout title="Contact — Wing Chun Leung" description="Get in touch with Wing Chun Leung.">
  <Header slot="header" />

  <section class="page-hero">
    <div class="container content">
      <span class="section-label">Contact</span>
      <h1>Let's talk</h1>
      <p class="hero-sub">
        Open to conversations about AI research, fintech, speaking, or anything in between.
      </p>
    </div>
  </section>

  <section class="contact-section">
    <div class="container content">
      <div class="contact-grid">
        {contacts.map((c, i) => (
          <a
            href={c.href}
            class="contact-card"
            data-animate="reveal"
            style={`--delay: ${i * 0.1}s`}
            target={c.external ? '_blank' : undefined}
            rel={c.external ? 'noopener noreferrer' : undefined}
          >
            <span class="contact-label">{c.label}</span>
            <span class="contact-value">{c.value}</span>
            <span class="contact-cta">
              {c.cta}
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M1 11L11 1M11 1H3M11 1v8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        ))}
      </div>

      <div class="location-block" data-animate="reveal">
        <span class="section-label">Based in</span>
        <p class="location-city">Hong Kong SAR</p>
        <p class="location-detail">HKUST, Clear Water Bay</p>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-hero {
    padding-top: calc(72px + var(--section-gap));
    padding-bottom: var(--space-6);
  }
  .page-hero .section-label {
    opacity: 0; transform: translateY(20px);
    animation: pr 0.8s var(--ease-out) 0.2s forwards;
  }
  .page-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    margin-top: var(--space-3); margin-bottom: var(--space-3);
    opacity: 0; transform: translateY(30px);
    animation: pr 0.8s var(--ease-out) 0.4s forwards;
  }
  .hero-sub {
    font-size: clamp(1rem, 1.8vw, 1.2rem);
    color: var(--color-wash); max-width: 480px;
    opacity: 0; transform: translateY(20px);
    animation: pr 0.8s var(--ease-out) 0.6s forwards;
  }
  @keyframes pr { to { opacity: 1; transform: translateY(0); } }

  .contact-section {
    padding-bottom: var(--section-gap);
  }

  .contact-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  .contact-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: var(--space-4) var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out),
                transform var(--duration-normal) var(--ease-out);
    opacity: 0; transform: translateY(30px);
    min-height: 44px;
  }

  .contact-card::after { display: none; }

  .contact-card.visible {
    opacity: 1; transform: translateY(0);
    transition: opacity var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                transform var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                border-color var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .contact-card:hover {
    border-color: var(--color-vermillion);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    color: var(--color-text);
  }

  .contact-label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-wash);
  }

  .contact-value {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-light);
  }

  .contact-cta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-small);
    color: var(--color-vermillion);
    margin-top: 4px;
  }

  .contact-cta svg {
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .contact-card:hover .contact-cta svg {
    transform: translate(3px, -3px);
  }

  .location-block {
    text-align: center;
    opacity: 0; transform: translateY(20px);
  }

  .location-block.visible {
    opacity: 1; transform: translateY(0);
    transition: opacity 0.8s var(--ease-out), transform 0.8s var(--ease-out);
  }

  .location-city {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-light);
    margin-top: var(--space-3);
    margin-bottom: var(--space-1);
  }

  .location-detail {
    color: var(--color-wash);
    font-size: var(--text-small);
  }
</style>

<script>
  const revealElements = document.querySelectorAll('[data-animate="reveal"]');
  if (revealElements.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );
    revealElements.forEach((el) => observer.observe(el));
  }
</script>
