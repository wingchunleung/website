---
/**
 * HCI Course Page — ARIN5301 (Prof. Xiaojuan Ma, HKUST)
 *
 * Audience: TA grading the course. Not a recruiter.
 * Register: lecture vocabulary, plain-language explanation, scannable rows.
 *
 * The page is meta-reflexive — it both describes HCI principles and is
 * itself the artefact under evaluation. Section order is:
 *   Hero → Assignments (with anchor TOC) → "How this page was designed"
 *   narrative → Principles reference appendix → Heuristic self-evaluation
 *   (severity 0–4 per HCI-08) → Footer
 *
 * Concept set is narrowed to what actually shaped this specific page.
 * Deferred concepts (HRI, XR, ubicomp, CSCW, persuasive tech, GOMS/HTA,
 * NASA-TLX, SUS, Activity Theory, Wizard of Oz, full fission/fusion theory)
 * live in docs/hci-deferred-for-writing.md and are excluded by design.
 *
 * Phase A research → Phase B multi-agent copy ideation → Phase C DDR-003
 * → this implementation. See design/decisions/003-hci-page-content-rewrite.md.
 *
 * HCI principles enacted (subset, full list cited inline in the narrative):
 * - H1 Consistency — celadon accent is the only deviation; tokens unchanged
 * - H2 Mapping — page organised by assignment (TA's mental model)
 * - H4 Freedom — anchor-link TOC for assignments, deep-linkable URLs
 * - H6 Recognition — canonical principle names bolded as in-page landmarks
 * - H8 / Need-typology Security — predictable placeholder copy, not hidden
 * - HCI-11 multimodal redundancy — colour never carries meaning alone
 * - HCI-08 expert inspection — single-evaluator audit at page bottom
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const assignments = [
  {
    slug: 'final-project',
    number: '01',
    title: 'Final Project',
    description: 'My HCI final project submission will be posted here once submitted.',
    date: 'TBD',
    status: 'upcoming' as const,
    emptyStateNote: 'If this slot is still empty when you grade, please reach me via the contact page.',
  },
];

// Lecture-by-lecture narrative — each entry names a course concept and
// the concrete decision it shaped on this specific page. Order is roughly
// bottom-up: perception → cognition → heuristics → mental-model gulfs →
// motivational layer → deployment. See DDR-003 for the rationale.
const lectures = [
  {
    source: 'HCI-02',
    principle: "Norman's three levels (visceral, behavioural, reflective)",
    application: 'A calm celadon hero handles the first emotional read (visceral); the repeating card structure makes the page feel predictable in use (behavioural); the honest self-audit at the bottom is what the page says about its author (reflective).',
  },
  {
    source: 'HCI-03',
    principle: 'Gestalt as cognitive-load engineering',
    application: 'Principles are split into three labelled groups instead of one long pile, with a wider gap between sections than within them (proximity), and every card built the same way (similarity) — so grouping reads pre-attentively rather than being parsed.',
  },
  {
    source: 'HCI-03',
    principle: "Miller's ~7 / chunking",
    application: 'Each principle category is capped at no more than ten items, and one long flat list was broken into three smaller groups so working memory has a chance.',
  },
  {
    source: 'HCI-08',
    principle: "Nielsen's heuristics with 0–4 severity scale",
    application: "The self-evaluation table below is structured around the ten heuristics, with the lecture's exact severity wording: 0 not-a-problem, 1 cosmetic, 2 minor, 3 major, 4 catastrophe.",
  },
  {
    source: 'HCI-08',
    principle: 'Heuristic evaluation as expert inspection (Rule of Five)',
    application: 'The audit is a single-evaluator pass, so the page openly states it covers around 35% of likely issues; reaching ~75% would need five inspectors.',
  },
  {
    source: 'UX models',
    principle: 'Implementation ↔ Representation ↔ Mental',
    application: 'The page is organised around assignments — which matches how a grader already thinks about coursework — rather than around lecture order, which is how the syllabus is built but not how the reader arrives.',
  },
  {
    source: 'Baseline',
    principle: 'Gulfs of execution and evaluation',
    application: 'Every assignment has its own anchor link, which closes the execution gulf — you can jump straight to one. Status pills marked Upcoming or Published close the evaluation gulf — you can see what is actually finished.',
  },
  {
    source: 'Need typology',
    principle: 'Competence and Security',
    application: 'Naming weaknesses out loud reads as competence rather than damage; placeholders marked TBD give the reader something steady to expect, which is the security need being met through predictability.',
  },
  {
    source: 'HCI-11 (subset)',
    principle: 'Multimodal redundancy',
    application: 'Status pills carry a colour and a written word together, so meaning survives a colour-blind reader or a greyscale screen. Celadon never carries information on its own.',
  },
  {
    source: 'HCI-18 (subset)',
    principle: 'Lab-to-world / deploy-and-verify',
    application: "The audit is run against the live deployed page rather than the local preview, because the lecture's point is that field findings don't always match preview findings.",
  },
];

// Severity scale — wording lifted verbatim from HCI-08.
const severityLegend = [
  { score: '0', label: 'Not a problem' },
  { score: '1', label: 'Cosmetic — fix if time allows' },
  { score: '2', label: 'Minor — low priority' },
  { score: '3', label: 'Major — important to fix' },
  { score: '4', label: 'Usability catastrophe — must fix' },
];

// Heuristic self-evaluation. Single-evaluator pass conducted before this
// revision; the remediation column states what changed in response.
// H3 stays at 2 even after the rewrite — adding any content increases load
// by definition, and that is the honest call. See DDR-003 §5.
const heuristicAudit = [
  {
    id: 'H1',
    name: 'Consistency & standards',
    severity: 0,
    justification: 'Celadon accent swap is the only deviation; layout, type, and spacing match the rest of the site.',
    remediation: '—',
  },
  {
    id: 'H2',
    name: 'Match real-world (Mapping)',
    severity: 1,
    justification: 'Page is structured by assignments — the grader\'s mental model — but the section header read "Coursework" rather than course-code language.',
    remediation: 'Header now reads "ARIN5301 deliverables".',
  },
  {
    id: 'H3',
    name: 'Aesthetic & minimalist',
    severity: 2,
    justification: 'The lecture-by-lecture narrative and this audit table are themselves added content on a page that argues for restraint. Honest cost.',
    remediation: 'Tight-row format, no prose paragraphs, severity legend on the same view as the table.',
  },
  {
    id: 'H4',
    name: 'User control & freedom',
    severity: 2,
    justification: 'No anchor TOC for assignments — once more arrive, a grader has to scroll past everything to reach a later one.',
    remediation: 'Anchor-link TOC at the top of Assignments.',
  },
  {
    id: 'H5',
    name: 'Flexibility & efficiency',
    severity: 3,
    justification: 'A time-pressed grader had no skip-to-assignments path, and no power-user shortcut to find a specific principle.',
    remediation: 'Anchor TOC plus the site-wide skip-to-content link, plus bolded canonical names that act as in-page landmarks.',
  },
  {
    id: 'H6',
    name: 'Recognition over recall',
    severity: 1,
    justification: 'The principles list is read-once; the severity scale would be unrecognised by a reader who has not taken HCI-08.',
    remediation: 'Severity legend adjacent to the audit; canonical principle names bolded throughout the narrative as recognition cues.',
  },
  {
    id: 'H7',
    name: 'Visibility of system status',
    severity: 1,
    justification: 'Site-wide scroll progress bar and status pills work, but no per-section indicator was added for this longer page.',
    remediation: 'Considered, deferred — the global progress bar is sufficient for a page of this length.',
  },
  {
    id: 'H8',
    name: 'Error prevention',
    severity: 0,
    justification: 'No forms, no destructive actions on this page.',
    remediation: '—',
  },
  {
    id: 'H9',
    name: 'Help users recover',
    severity: 1,
    justification: 'The "TBD" placeholder did not tell a grader what to do if the slot was still empty on grading day.',
    remediation: 'Empty-state copy now points to the contact page if the slot is empty when read.',
  },
  {
    id: 'H10',
    name: 'Help & documentation',
    severity: 2,
    justification: 'The 0–4 severity vocabulary used in the audit was not defined for a reader unfamiliar with HCI-08.',
    remediation: 'Severity legend box placed adjacent to the audit table.',
  },
];

const principles = [
  {
    category: 'Usability Heuristics',
    items: [
      { name: 'Consistency', description: 'Internal, external, and metaphorical consistency across the interface.' },
      { name: 'Mapping', description: 'Match between system and real world — use language users understand.' },
      { name: 'Minimalism', description: 'Every extra element competes with relevant information.' },
      { name: 'Freedom', description: 'User control — undo, redo, emergency exits.' },
      { name: 'Flexibility', description: 'Accelerators for experts, support for novices.' },
      { name: 'Recognition', description: 'Make options visible rather than requiring recall.' },
      { name: 'Visibility', description: 'Keep users informed about system status.' },
      { name: 'Error Prevention', description: 'Prevent errors before they occur through constraints.' },
      { name: 'Error Recovery', description: 'Help users recognize, diagnose, and recover from errors.' },
      { name: 'Help', description: 'Provide help and documentation when needed.' },
    ],
  },
  {
    category: 'Gestalt Principles',
    items: [
      { name: 'Proximity', description: 'Close elements are perceived as related groups.' },
      { name: 'Similarity', description: 'Similar elements are perceived as belonging together.' },
      { name: 'Continuation', description: 'Elements on a line or curve are seen as related.' },
      { name: 'Closure', description: 'The mind completes incomplete shapes.' },
      { name: 'Figure-Ground', description: 'Users distinguish foreground from background.' },
      { name: 'Common Fate', description: 'Elements moving together are grouped.' },
      { name: 'Symmetry', description: 'Balanced elements are perceived as unified.' },
    ],
  },
  {
    category: 'Design Levels',
    items: [
      { name: 'Visceral', description: 'Immediate emotional reaction — sensation, first impression.' },
      { name: 'Behavioral', description: 'Usability and function — does it work well?' },
      { name: 'Reflective', description: 'Meaning and self-image — what does it say about me?' },
    ],
  },
];
---

<BaseLayout
  title="HCI — Wing Chun Leung"
  description="ARIN5301 Human-Computer Interaction coursework by Wing Chun Leung at HKUST."
  accent="celadon"
>
  <Header slot="header" />

  <section class="page-hero hci-hero">
    <div class="container content">
      <span class="section-label">ARIN5301</span>
      <h1>Human-Computer<br />Interaction</h1>
      <p class="page-subtitle">
        Coursework and explorations from Prof. Xiaojuan Ma's HCI course at HKUST.
        This page is itself a demonstration of the principles it describes.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       ASSIGNMENTS
       HCI: H2 Mapping — structured by assignment (TA's mental model)
       HCI: H4 Freedom — TOC + deep-linkable anchors close the execution gulf
       HCI: Need-typology Security — placeholders predictable, not hidden
       ═══════════════════════════════════════════════════════════════════ -->
  <section id="assignments" class="assignments-section" aria-labelledby="assignments-heading">
    <div class="container content">
      <div class="section-header" data-animate="reveal">
        <span class="section-label">ARIN5301 deliverables</span>
        <h2 id="assignments-heading">Coursework</h2>
      </div>

      <nav class="assignments-toc" aria-label="Jump to an assignment" data-animate="reveal">
        <span class="assignments-toc-label">Jump to</span>
        <ul class="assignments-toc-list" role="list">
          {assignments.map((assignment) => (
            <li>
              <a href={`#assignment-${assignment.slug}`} class="assignments-toc-link">
                <span class="assignments-toc-number">{assignment.number}</span>
                <span class="assignments-toc-title">{assignment.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="assignments-list">
        {assignments.map((assignment) => (
          <article id={`assignment-${assignment.slug}`} class="assignment-card" data-animate="reveal">
            <div class="assignment-number" aria-hidden="true">{assignment.number}</div>
            <div class="assignment-content">
              <h3 class="assignment-title">{assignment.title}</h3>
              <p class="assignment-description">{assignment.description}</p>
              {assignment.emptyStateNote && (
                <p class="assignment-empty-note">{assignment.emptyStateNote}</p>
              )}
              <div class="assignment-meta">
                <span class="assignment-date">{assignment.date}</span>
                <span class:list={['assignment-status', assignment.status]}>
                  {assignment.status === 'upcoming' ? 'Upcoming' : 'Published'}
                </span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       HOW THIS PAGE WAS DESIGNED
       Meta-reflexive narrative — names the lecture concept behind each
       concrete decision on this specific page. One framing paragraph,
       then ten plain-language rows. Order is bottom-up: perception →
       cognition → heuristics → mental-model gulfs → motivational layer
       → deployment. See DDR-003.
       ═══════════════════════════════════════════════════════════════════ -->
  <section id="how-designed" class="lectures-section" aria-labelledby="lectures-heading">
    <div class="container content">
      <div class="section-header" data-animate="reveal">
        <span class="section-label">How this page was designed</span>
        <h2 id="lectures-heading">Lecture concepts that shaped this page</h2>
      </div>

      <p class="lectures-intro" data-animate="reveal">
        This page is the artefact under evaluation. Each entry below names a course
        concept and the concrete decision it shaped on this page — read it as
        evidence, not slogans.
      </p>

      <ol class="lectures-list" role="list">
        {lectures.map((lecture, i) => (
          <li class="lecture-row" data-animate="reveal" style={`--delay: ${i * 0.04}s`}>
            <div class="lecture-source-block">
              <span class="lecture-source">{lecture.source}</span>
              <span class="lecture-principle">{lecture.principle}</span>
            </div>
            <p class="lecture-application">{lecture.application}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       PRINCIPLES — REFERENCE APPENDIX
       Demoted from "main content" to "glossary." Vocabulary used in the
       narrative above, listed for quick lookup.
       Gestalt: Proximity — principles grouped by category
       Gestalt: Similarity — consistent card design within categories
       Miller's ~7 — each category capped at ≤10 items
       ═══════════════════════════════════════════════════════════════════ -->
  <section id="principles" class="principles-section" aria-labelledby="principles-heading">
    <div class="container">
      <div class="content">
        <span class="section-label">Reference appendix</span>
        <h2 id="principles-heading">Vocabulary used above</h2>
        <p class="principles-intro">
          The principle names referenced in the narrative. Listed here for quick
          lookup; not new content.
        </p>
      </div>

      <div class="principles-grid">
        {principles.map((group) => (
          <div class="principle-group" data-animate="reveal">
            <h3 class="group-title">{group.category}</h3>
            <ul class="principle-list">
              {group.items.map((item) => (
                <li class="principle-item">
                  <span class="principle-name">{item.name}</span>
                  <span class="principle-desc">{item.description}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       HEURISTIC SELF-EVALUATION
       HCI-08 expert inspection format. Single-evaluator pass conducted
       before this revision; the remediation column shows what changed in
       response. Severity legend precedes the table so the vocabulary is
       established before any rating is read (H10 Help & documentation).
       ═══════════════════════════════════════════════════════════════════ -->
  <section id="audit" class="audit-section" aria-labelledby="audit-heading">
    <div class="container content">
      <div class="section-header" data-animate="reveal">
        <span class="section-label">Heuristic self-evaluation</span>
        <h2 id="audit-heading">Audit and response</h2>
      </div>

      <p class="audit-intro" data-animate="reveal">
        Findings from a single-evaluator inspection conducted before this
        revision, scored against Nielsen's ten heuristics (HCI-08). The Rule of
        Five says one inspector catches roughly 35% of likely issues — five
        catch around 75% — so this audit is not exhaustive. The remediation
        column states what changed in response.
      </p>

      <aside class="severity-legend" aria-label="Severity scale (HCI-08)" data-animate="reveal">
        <span class="severity-legend-title">Severity scale (HCI-08)</span>
        <ul class="severity-legend-list" role="list">
          {severityLegend.map((entry) => (
            <li class="severity-legend-item">
              <span class="severity-legend-score">{entry.score}</span>
              <span class="severity-legend-label">{entry.label}</span>
            </li>
          ))}
        </ul>
      </aside>

      <div class="audit-table-wrap" data-animate="reveal">
        <table class="audit-table">
          <thead>
            <tr>
              <th scope="col" class="audit-th-id">#</th>
              <th scope="col" class="audit-th-name">Heuristic</th>
              <th scope="col" class="audit-th-severity">Severity</th>
              <th scope="col" class="audit-th-justification">Justification</th>
              <th scope="col" class="audit-th-remediation">Remediation</th>
            </tr>
          </thead>
          <tbody>
            {heuristicAudit.map((row) => (
              <tr>
                <td class="audit-id" data-label="#">{row.id}</td>
                <td class="audit-name" data-label="Heuristic">{row.name}</td>
                <td class="audit-severity" data-label="Severity">
                  <span class:list={['severity-pill', `severity-${row.severity}`]}>
                    {row.severity}
                  </span>
                </td>
                <td class="audit-justification" data-label="Justification">{row.justification}</td>
                <td class="audit-remediation" data-label="Remediation">{row.remediation}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="audit-note" data-animate="reveal">
        H3 stays at severity 2 even after this revision. Adding any content
        increases load by definition; the trade is that without it the page
        cannot demonstrate HCI thinking at all. The full reasoning is in
        DDR-003 (<code>design/decisions/003-hci-page-content-rewrite.md</code>).
      </p>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* HCI page uses celadon accent */
  .hci-hero {
    background: var(--color-surface);
  }

  .page-hero {
    padding-top: calc(72px + var(--section-gap));
    padding-bottom: var(--space-8);
  }

  .page-hero .section-label {
    opacity: 0;
    transform: translateY(20px);
    animation: pageReveal 0.8s var(--ease-out) 0.2s forwards;
  }

  .page-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    margin-top: var(--space-3);
    margin-bottom: var(--space-3);
    opacity: 0;
    transform: translateY(30px);
    animation: pageReveal 0.8s var(--ease-out) 0.4s forwards;
    background: linear-gradient(135deg, var(--color-ink) 0%, var(--color-celadon) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .page-subtitle {
    color: var(--color-text-secondary);
    max-width: 55ch;
    opacity: 0;
    transform: translateY(20px);
    animation: pageReveal 0.8s var(--ease-out) 0.6s forwards;
  }

  @keyframes pageReveal {
    to { opacity: 1; transform: translateY(0); }
  }

  .section-header {
    margin-bottom: var(--space-5);
    opacity: 0; transform: translateY(30px);
  }
  .section-header.visible {
    opacity: 1; transform: translateY(0);
    transition: opacity 0.8s var(--ease-out), transform 0.8s var(--ease-out);
  }
  .section-header h2 { margin-top: var(--space-2); }

  /* Assignments */
  .assignments-section {
    padding: var(--section-gap) 0;
  }

  /* h2 styled via .section-header */

  .assignments-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .assignment-card {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-celadon);
    border-radius: var(--radius-lg);
    opacity: 0;
    transform: translateY(30px);
    transition: transform var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .assignment-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .assignment-card.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity var(--duration-reveal) var(--ease-out),
                transform var(--duration-reveal) var(--ease-out);
  }

  .assignment-number {
    font-family: var(--font-mono);
    font-size: var(--text-h2);
    color: var(--color-celadon);
    font-weight: var(--weight-medium);
    line-height: 1;
    min-width: 2ch;
  }

  .assignment-title {
    font-size: var(--text-h3);
    margin-bottom: var(--space-1);
  }

  .assignment-description {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2);
  }

  .assignment-meta {
    display: flex;
    gap: var(--space-3);
    align-items: center;
  }

  .assignment-date {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-wash);
  }

  .assignment-status {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  .assignment-status.upcoming {
    color: var(--color-celadon);
    background: rgba(125, 158, 140, 0.1);
  }

  .assignment-status.published {
    color: var(--color-vermillion);
    background: rgba(199, 62, 29, 0.1);
  }

  .assignment-empty-note {
    font-size: var(--text-small);
    color: var(--color-wash);
    font-style: italic;
    margin-bottom: var(--space-2);
    max-width: 60ch;
  }

  /* Assignments TOC — closes the execution gulf for graders.
     H4/H5 fix landing in this revision (DDR-003 §5). */
  .assignments-toc {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    border-radius: var(--radius-md);
    border-left: 2px solid var(--color-celadon);
  }

  .assignments-toc-label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-wash);
  }

  .assignments-toc-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin: 0;
    padding: 0;
  }

  .assignments-toc-link {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
    font-size: var(--text-small);
    color: var(--color-text);
    text-decoration: none;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    transition: background var(--duration-normal) var(--ease-out),
                color var(--duration-normal) var(--ease-out);
  }

  .assignments-toc-link::after { display: none; }

  .assignments-toc-link:hover {
    background: rgba(125, 158, 140, 0.1);
    color: var(--color-celadon);
  }

  .assignments-toc-number {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-celadon);
  }

