---
/**
 * HCI Course Page — ARIN5301 (Prof. Xiaojuan Ma, HKUST)
 *
 * Three sections: hero → coursework (assignments with phases) → principles.
 *
 * A "phase" is a deliverable. It can carry a project title, a video or PDF
 * artifact, a multi-paragraph description, and acknowledgments. Two render
 * modes:
 *   - Rich phase (artifact.inline === true): the iframe is always visible
 *     directly inside the card; the description collapses to ~3 lines with a
 *     "Show more" toggle (H3 minimalist on small screens, H4 user control).
 *   - Disclosure phase (artifact present, inline !== true): native <details>
 *     keeps the artifact behind a click-to-expand row.
 *   - Static phase (no artifact): plain row with an Upcoming pill.
 *
 * HCI principles enacted:
 * - H1 Consistency — celadon accent is the only deviation; tokens unchanged
 * - H2 Mapping — page organised by assignment (TA's mental model)
 * - H3 Minimalism — long descriptions truncate to 3 lines on every viewport
 * - H4 Freedom — show-more is reversible; details disclosure is opt-in
 * - H6 Recognition — phase status pills surface state without recall
 * - HCI-11 multimodal redundancy — colour never carries meaning alone
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

type Artifact =
  | {
      type: 'pdf' | 'video';
      src: string;                 // embed URL (used by the iframe)
      href: string;                // direct/external URL (used by "open in new tab")
      cta?: string;                // CTA wording for the disclosure variant
      inline?: boolean;            // if true, embed renders always-visible
    }
  | {
      type: 'slides';
      slides: string[];            // list of pre-rendered slide image URLs
      href: string;                // direct/external URL (PDF download fallback)
      cta?: string;
      inline?: boolean;
    };

type Phase = {
  label: string;
  title?: string;
  projectTitle?: string;
  status: 'completed' | 'upcoming';
  note?: string;
  description?: string;            // paragraphs separated by \n\n
  acknowledgments?: string[];
  artifact?: Artifact;
};

type Assignment = {
  slug: string;
  number: string;
  title: string;
  description?: string;            // brief assignment-level intro
  phases: Phase[];
};

const assignments: Assignment[] = [
  {
    slug: 'final-project',
    number: '01',
    title: 'Final Project (Individual)',
    phases: [
      {
        label: 'Phase 1',
        title: 'Video paper',
        projectTitle: 'The Good, the Bad, the Trade-off',
        status: 'completed',
        artifact: {
          type: 'video',
          src: 'https://drive.google.com/file/d/1pO1i1KePp4WZ-5EwFprDSA87u-MNMQMU/preview',
          href: 'https://drive.google.com/file/d/1pO1i1KePp4WZ-5EwFprDSA87u-MNMQMU/view?usp=sharing',
          inline: true,
        },
        description: [
          'Kimi Claw is a 24/7 AI assistant released in February 2026. This application is built on top of OpenClaw, with full integration into Kimi’s ecosystem (using Kimi’s AI model and cloud infrastructure). Kimi Claw aims to automate complex tasks and improve users’ efficiency. However, despite its capabilities, it comes with pros and cons. Due to time constraints, the video focuses on the user desirability aspect.',
          'In terms of pros, there are 3 main advantages. First, it offers strong automation. Users can input natural language commands, which Kimi Claw automatically translates into executable code. This eliminates the need for manual installation and implementation. Second, it is easy to set up. I recall when I set up my self-hosted OpenClaw on a virtual private server (VPS), it took me a day just to get it functional. However, Kimi Claw allows users to deploy the AI agent with just a few clicks, saving time and reducing cognitive load. Third, it has low maintenance. As OpenClaw has frequent updates, manually tracking and updating can be time-consuming. At Kimi Claw, updates are handled by the Kimi platform, and users can upgrade with a one click.',
          'Despite the above pros, there are 2 disadvantages. First, Kimi Claw violates the invisible computing principle. Unlike the original OpenClaw, Kimi Claw shows all the reasoning for each operation. While this allows users to review its current status, it becomes overwhelming over time (e.g., dozens of messages for a single operation). Second is the over-automation issue. Unlike traditional coding, where code is visible, changes using Kimi Code occur in a black box, making it unclear what is modified or whether new issues have been introduced.',
          'With that, we can see that, despite its strengths, Kimi Claw presents a trade-off — convenience at the expense of reduced transparency and control.',
        ].join('\n\n'),
        acknowledgments: [
          'Copyright: Some images used in the video were sourced from publicly available sources via online searches (e.g., Google). All rights belong to their respective owners. This video is created for educational purposes only.',
          'AI use: The short introduction is edited by Grammarly, an AI-powered writing tool, to refine grammar and sentence structure. All suggestions were reviewed manually to preserve tone.',
        ],
      },
      {
        label: 'Phase 2',
        status: 'upcoming',
        note: 'TBD',
      },
    ],
  },
  {
    slug: 'group-project',
    number: '02',
    title: 'Group Project',
    description: 'ARIN5301 Group 5 — collaborative coursework across the term.',
    phases: [
      {
        label: 'Phase 1',
        title: 'Need-finding',
        status: 'completed',
        note: 'Slide deck presented in class',
        artifact: {
          type: 'slides',
          slides: Array.from({ length: 19 }, (_, i) =>
            `/files/group-project-slides/slide-${String(i + 1).padStart(2, '0')}.jpg`,
          ),
          href: '/files/group-project-needfinding-phase1.pdf',
          inline: true,
        },
      },
      {
        label: 'Phase 2',
        status: 'upcoming',
        note: 'TBD',
      },
    ],
  },
];

const principles = [
  {
    category: 'Usability Heuristics',
    items: [
      { name: 'Consistency', description: 'Internal, external, and metaphorical consistency across the interface.' },
      { name: 'Mapping', description: 'Match between system and real world — use language users understand.' },
      { name: 'Minimalism', description: 'Every extra element competes with relevant information.' },
      { name: 'Freedom', description: 'User control — undo, redo, emergency exits.' },
      { name: 'Flexibility', description: 'Accelerators for experts, support for novices.' },
      { name: 'Recognition', description: 'Make options visible rather than requiring recall.' },
      { name: 'Visibility', description: 'Keep users informed about system status.' },
      { name: 'Error Prevention', description: 'Prevent errors before they occur through constraints.' },
      { name: 'Error Recovery', description: 'Help users recognize, diagnose, and recover from errors.' },
      { name: 'Help', description: 'Provide help and documentation when needed.' },
    ],
  },
  {
    category: 'Gestalt Principles',
    items: [
      { name: 'Proximity', description: 'Close elements are perceived as related groups.' },
      { name: 'Similarity', description: 'Similar elements are perceived as belonging together.' },
      { name: 'Continuation', description: 'Elements on a line or curve are seen as related.' },
      { name: 'Closure', description: 'The mind completes incomplete shapes.' },
      { name: 'Figure-Ground', description: 'Users distinguish foreground from background.' },
      { name: 'Common Fate', description: 'Elements moving together are grouped.' },
      { name: 'Symmetry', description: 'Balanced elements are perceived as unified.' },
    ],
  },
  {
    category: 'Design Levels',
    items: [
      { name: 'Visceral', description: 'Immediate emotional reaction — sensation, first impression.' },
      { name: 'Behavioral', description: 'Usability and function — does it work well?' },
      { name: 'Reflective', description: 'Meaning and self-image — what does it say about me?' },
    ],
  },
];
---

<BaseLayout
  title="HCI — Wing Chun Leung"
  description="ARIN5301 Human-Computer Interaction coursework by Wing Chun Leung at HKUST."
  accent="celadon"
>
  <Header slot="header" />

  <section class="page-hero hci-hero">
    <div class="container content">
      <span class="section-label">ARIN5301</span>
      <h1>Human-Computer<br />Interaction</h1>
      <p class="page-subtitle">
        Coursework from Prof. Xiaojuan Ma's HCI course at HKUST.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       ASSIGNMENTS
       ═══════════════════════════════════════════════════════════════════ -->
  <section id="assignments" class="assignments-section" aria-labelledby="assignments-heading">
    <div class="container content">
      <div class="section-header" data-animate="reveal">
        <span class="section-label">ARIN5301 deliverables</span>
        <h2 id="assignments-heading">Coursework</h2>
      </div>

      <nav class="assignments-toc" aria-label="Jump to an assignment" data-animate="reveal">
        <span class="assignments-toc-label">Jump to</span>
        <ul class="assignments-toc-list" role="list">
          {assignments.map((assignment) => (
            <li>
              <a href={`#assignment-${assignment.slug}`} class="assignments-toc-link">
                <span class="assignments-toc-number">{assignment.number}</span>
                <span class="assignments-toc-title">{assignment.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="assignments-list">
        {assignments.map((assignment) => (
          <article id={`assignment-${assignment.slug}`} class="assignment-card" data-animate="reveal">
            <div class="assignment-number" aria-hidden="true">{assignment.number}</div>
            <div class="assignment-content">
              <h3 class="assignment-title">{assignment.title}</h3>
              {assignment.description && (
                <p class="assignment-description">{assignment.description}</p>
              )}

              <ul class="phase-list" role="list">
                {assignment.phases.map((phase) => (
                  <li class="phase-item">
                    {phase.artifact?.inline ? (
                      <div class="phase phase-rich">
                        <div class="phase-summary phase-summary-static">
                          <span class="phase-summary-main">
                            <span class="phase-num">{phase.label}</span>
                            {phase.title && <span class="phase-title">{phase.title}</span>}
                            <span class:list={['phase-status', phase.status]}>
                              {phase.status === 'completed' ? 'Done' : 'Upcoming'}
                            </span>
                          </span>
                        </div>

                        {phase.projectTitle && (
                          <p class="phase-project-title">{phase.projectTitle}</p>
                        )}

                        {phase.artifact.type === 'video' && (
                          <iframe
                            class="phase-embed phase-embed-video"
                            src={phase.artifact.src}
                            title={`${phase.label}${phase.projectTitle ? ': ' + phase.projectTitle : ''}`}
                            loading="lazy"
                            allow="autoplay; fullscreen"
                            allowfullscreen
                          ></iframe>
                        )}

                        {phase.artifact.type === 'pdf' && (
                          <iframe
                            class="phase-embed phase-embed-pdf"
                            src={phase.artifact.src}
                            title={`${phase.label}${phase.projectTitle ? ': ' + phase.projectTitle : ''}`}
                            loading="lazy"
                          ></iframe>
                        )}

                        {phase.artifact.type === 'slides' && (
                          <div
                            class="slide-viewer"
                            tabindex="0"
                            data-slide-viewer
                            data-slide-count={phase.artifact.slides.length}
                            aria-roledescription="carousel"
                            aria-label={`${assignment.title} — ${phase.label}${phase.title ? ': ' + phase.title : ''}`}
                          >
                            <div class="slide-viewer-stage">
                              {phase.artifact.slides.map((src, i) => (
                                <img
                                  class:list={['slide-viewer-slide', { 'is-current': i === 0 }]}
                                  src={src}
                                  alt={`Slide ${i + 1} of ${phase.artifact.slides.length}`}
                                  loading={i === 0 ? 'eager' : 'lazy'}
                                  data-slide-index={i}
                                  draggable="false"
                                />
                              ))}
                            </div>
                            <div class="slide-viewer-controls">
                              <button type="button" class="slide-viewer-btn" data-slide-prev aria-label="Previous slide" disabled>
                                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                                  <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                              </button>
                              <span class="slide-viewer-counter" data-slide-counter>1 / {phase.artifact.slides.length}</span>
                              <button type="button" class="slide-viewer-btn" data-slide-next aria-label="Next slide">
                                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                                  <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                              </button>
                              <span class="slide-viewer-hint">Use ← → keys</span>
                            </div>
                          </div>
                        )}

                        <a href={phase.artifact.href} target="_blank" rel="noopener noreferrer" class="phase-external">
                          {phase.artifact.type === 'slides' ? 'Download PDF' : 'Open in new tab'}
                          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                            <path d="M1 11L11 1M11 1H3M11 1v8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        </a>

                        {phase.description && (
                          <div class="description-clip" data-expanded="false">
                            <div class="description-body">
                              {phase.description.split('\n\n').map((para) => (
                                <p class="description-para">{para}</p>
                              ))}
                            </div>
                            <button
                              type="button"
                              class="description-toggle"
                              aria-expanded="false"
                              data-toggle-description
                            >
                              <span class="description-toggle-label">Show more</span>
                              <svg class="description-toggle-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                                <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                            </button>
                          </div>
                        )}

                        {phase.acknowledgments && phase.acknowledgments.length > 0 && (
                          <div class="phase-acknowledgments">
                            <span class="acknowledgments-label">Acknowledgments</span>
                            {phase.acknowledgments.map((line) => (
                              <p class="acknowledgments-line">{line}</p>
                            ))}
                          </div>
                        )}
                      </div>
                    ) : phase.artifact ? (
                      <details class="phase">
                        <summary class="phase-summary">
                          <span class="phase-summary-main">
                            <span class="phase-num">{phase.label}</span>
                            {phase.title && <span class="phase-title">{phase.title}</span>}
                            <span class:list={['phase-status', phase.status]}>
                              {phase.status === 'completed' ? 'Done' : 'Upcoming'}
                            </span>
                          </span>
                          {phase.note && <span class="phase-note">{phase.note}</span>}
                          <span class="phase-cta">
                            <span>{phase.artifact.cta ?? 'View'}</span>
                            <span class="phase-arrow" aria-hidden="true">
                              <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                                <path d="M3 1l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                            </span>
                          </span>
                        </summary>
                        <div class="phase-artifact">
                          {phase.artifact.type === 'pdf' ? (
                            <iframe
                              class="phase-embed phase-embed-pdf"
                              src={phase.artifact.src}
                              title={`${assignment.title} — ${phase.label}${phase.title ? ': ' + phase.title : ''}`}
                              loading="lazy"
                            ></iframe>
                          ) : (
                            <iframe
                              class="phase-embed phase-embed-video"
                              src={phase.artifact.src}
                              title={`${assignment.title} — ${phase.label}${phase.title ? ': ' + phase.title : ''}`}
                              loading="lazy"
                              allow="autoplay; fullscreen"
                              allowfullscreen
                            ></iframe>
                          )}
                          <a href={phase.artifact.href} target="_blank" rel="noopener noreferrer" class="phase-external">
                            Open in new tab
                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                              <path d="M1 11L11 1M11 1H3M11 1v8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                          </a>
                        </div>
                      </details>
                    ) : (
                      <div class="phase phase-static">
                        <span class="phase-summary-main">
                          <span class="phase-num">{phase.label}</span>
                          {phase.title && <span class="phase-title">{phase.title}</span>}
                          <span class:list={['phase-status', phase.status]}>
                            {phase.status === 'completed' ? 'Done' : 'Upcoming'}
                          </span>
                        </span>
                        {phase.note && <span class="phase-note">{phase.note}</span>}
                      </div>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       PRINCIPLES
       Gestalt: Proximity + Similarity; Miller's ~7 — each cap ≤10 items
       ═══════════════════════════════════════════════════════════════════ -->
  <section id="principles" class="principles-section" aria-labelledby="principles-heading">
    <div class="container">
      <div class="content">
        <span class="section-label">Reference</span>
        <h2 id="principles-heading">HCI principles</h2>
      </div>

      <div class="principles-grid">
        {principles.map((group) => (
          <div class="principle-group" data-animate="reveal">
            <h3 class="group-title">{group.category}</h3>
            <ul class="principle-list">
              {group.items.map((item) => (
                <li class="principle-item">
                  <span class="principle-name">{item.name}</span>
                  <span class="principle-desc">{item.description}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* HCI page uses celadon accent */
  .hci-hero {
    background: var(--color-surface);
  }

  .page-hero {
    padding-top: calc(72px + var(--section-gap));
    padding-bottom: var(--space-8);
  }

  .page-hero .section-label {
    opacity: 0;
    transform: translateY(20px);
    animation: pageReveal 0.8s var(--ease-out) 0.2s forwards;
  }

  .page-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    margin-top: var(--space-3);
    margin-bottom: var(--space-3);
    opacity: 0;
    transform: translateY(30px);
    animation: pageReveal 0.8s var(--ease-out) 0.4s forwards;
    background: linear-gradient(135deg, var(--color-ink) 0%, var(--color-celadon) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .page-subtitle {
    color: var(--color-text-secondary);
    max-width: 55ch;
    opacity: 0;
    transform: translateY(20px);
    animation: pageReveal 0.8s var(--ease-out) 0.6s forwards;
  }

  @keyframes pageReveal {
    to { opacity: 1; transform: translateY(0); }
  }

  .section-header {
    margin-bottom: var(--space-5);
    opacity: 0; transform: translateY(30px);
  }
  .section-header.visible {
    opacity: 1; transform: translateY(0);
    transition: opacity 0.8s var(--ease-out), transform 0.8s var(--ease-out);
  }
  .section-header h2 { margin-top: var(--space-2); }

  /* Assignments */
  .assignments-section {
    padding: var(--section-gap) 0;
  }

  .assignments-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .assignment-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-celadon);
    border-radius: var(--radius-lg);
    opacity: 0;
    transform: translateY(30px);
    transition: transform var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .assignment-card:hover {
    box-shadow: var(--shadow-md);
  }

  .assignment-card.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity var(--duration-reveal) var(--ease-out),
                transform var(--duration-reveal) var(--ease-out);
  }

  .assignment-number {
    font-family: var(--font-mono);
    font-size: var(--text-h2);
    color: var(--color-celadon);
    font-weight: var(--weight-medium);
    line-height: 1;
    min-width: 2ch;
  }

  .assignment-content {
    flex: 1;
    min-width: 0;
  }

  .assignment-title {
    font-size: var(--text-h3);
    margin-bottom: var(--space-1);
  }

  .assignment-description {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-3);
    max-width: 65ch;
  }

  /* Phase list — one row per phase */
  .phase-list {
    list-style: none;
    margin: var(--space-3) 0 0;
    padding: 0;
    border-top: 1px solid var(--color-border);
  }

  .phase-item + .phase-item {
    border-top: 1px solid var(--color-border);
  }

  .phase {
    padding: var(--space-3) 0;
  }

  .phase-summary {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2) var(--space-3);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .phase-summary-static {
    cursor: default;
    user-select: auto;
  }

  /* Hide the default disclosure marker — we render our own arrow */
  .phase-summary::-webkit-details-marker { display: none; }
  .phase-summary::marker { content: ''; display: none; }

  .phase-summary-main {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .phase-num {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-celadon);
    font-weight: var(--weight-medium);
  }

  .phase-title {
    font-size: var(--text-body);
    font-weight: var(--weight-medium);
    color: var(--color-text);
  }

  .phase-status {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  .phase-status.completed {
    color: var(--color-celadon);
    background: rgba(125, 158, 140, 0.12);
  }

  .phase-status.upcoming {
    color: var(--color-wash);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
  }

  .phase-note {
    font-size: var(--text-small);
    color: var(--color-wash);
    flex: 1 1 12rem;
    min-width: 0;
  }

  .phase-cta {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-small);
    font-weight: var(--weight-medium);
    color: var(--color-celadon);
    flex-shrink: 0;
  }

  .phase-arrow {
    display: inline-flex;
    align-items: center;
    transition: transform var(--duration-normal) var(--ease-out);
  }

  details[open] > .phase-summary .phase-arrow {
    transform: rotate(90deg);
  }

  .phase-summary:hover .phase-cta {
    color: var(--color-ink);
  }

  /* Static (non-interactive) phase row */
  .phase-static {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2) var(--space-3);
    color: var(--color-wash);
  }

  /* ── Rich phase: project title + always-on embed + foldable description ── */
  .phase-rich {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .phase-project-title {
