---
/**
 * HCI Course Page — ARIN5301
 * Celadon accent (rather than the vermillion used elsewhere).
 *
 * Meta-reflexive: this page applies the principles it describes.
 *   H1 (Consistency) — same layout system, different accent
 *   H6 (Recognition) — assignments deep-linkable, principles named in copy
 *   Gestalt (Proximity, Similarity) — section spacing and card patterns are
 *     the grouping signal
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const assignments = [
  {
    number: '01',
    title: 'Final Project',
    description: 'My HCI final project submission will be posted here.',
    date: 'TBD',
    status: 'upcoming' as const,
  },
];

const principles = [
  {
    category: 'Usability Heuristics',
    items: [
      { name: 'Consistency', description: 'Internal, external, metaphorical. Patterns repeat across pages.' },
      { name: 'Mapping', description: 'Language and order match the visitor\'s mental model.' },
      { name: 'Minimalism', description: 'Every element earns its place. Decoration is cut.' },
      { name: 'Freedom', description: 'Deep links, escape routes, no scroll-jack.' },
      { name: 'Flexibility', description: 'Keyboard paths for fast use, reduced-motion respected.' },
      { name: 'Recognition', description: 'Visible labels. Never icon-only.' },
      { name: 'Visibility', description: 'Hover, focus, and reveal confirm state.' },
      { name: 'Error Prevention', description: '44×44px targets, predictable URLs, trailing slashes.' },
      { name: 'Error Recovery', description: 'A 404 page that points home.' },
      { name: 'Help', description: 'Section labels carry context. No separate help screen.' },
    ],
  },
  {
    category: 'Gestalt — cognitive load',
    items: [
      { name: 'Proximity', description: 'Gap difference is the grouping signal.' },
      { name: 'Similarity', description: 'Same pattern means same kind of thing.' },
      { name: 'Continuation', description: 'Left edge anchors, baselines guide the eye.' },
      { name: 'Closure', description: 'Partial reveals invite the scroll.' },
      { name: 'Figure-Ground', description: 'White cards lift content off the surface.' },
      { name: 'Common Fate', description: 'Staggered motion binds related items.' },
      { name: 'Symmetry', description: 'Centered hero, balanced two-column on tablet.' },
    ],
  },
  {
    category: 'Norman\'s three levels',
    items: [
      { name: 'Visceral', description: 'First emotion. Bright, warm, calm.' },
      { name: 'Behavioral', description: 'Fast, predictable, readable.' },
      { name: 'Reflective', description: 'Craft signals — type pairing, kerning, motion polish.' },
    ],
  },
];

const insights = [
  {
    label: '01',
    title: 'Gestalt is cognitive-load engineering',
    body: 'Spacing is not decoration. The 128px between sections tells working memory "new chapter, drop the old context." Tighter gaps inside a card say "one thought." Grouping does the work the eye would otherwise have to.',
  },
  {
    label: '02',
    title: 'Needs sit above usability',
    body: 'A site can pass every heuristic and still feel cold. Norman handles the surface; the need typology handles motivation. Autonomy (no autoplay), competence (project metrics over buzzwords), relatedness (warm tone, real photos), security (predictable links, fast load) — these are why a usable page also feels welcome.',
  },
  {
    label: '03',
    title: 'Color is never the only signal',
    body: 'Every accent state pairs with text or shape. Animation conveys delight, never meaning — content stays intelligible with reduced motion on. 8% of male visitors are color-blind, 0.5% of female. The redundancy is the floor, not a flourish.',
  },
  {
    label: '04',
    title: 'Lab is not the world',
    body: 'A page that works in dev can still flash unstyled on the live URL — GitHub Pages 301-redirects /about to /about/, and the round-trip costs the styles. Every change ends with a click of every nav link on production, on real mobile, before it counts as done.',
  },
];

const tradeoffs = [
  {
    title: 'Welcome over information density',
    body: 'The hero shows a greeting and a wave. No metric grid, no résumé tiles. A recruiter who wants density scrolls one screen — the trade chose visceral first impression over information per pixel.',
  },
  {
    title: 'Motion vs. accessibility',
    body: 'Reveals add behavioral feedback (H7) and a sense of rhythm. They also add ~12KB of JavaScript and risk vestibular discomfort. Mitigation: prefers-reduced-motion zeroes durations; staggers cap at 0.12s; no parallax. Motion is small by design.',
  },
  {
    title: 'Theory inline vs. flow',
    body: 'This page names principles (H1, H6, Gestalt) where general visitors do not need them. The cost is friction. The /hci page accepts that cost — the audience is HCI graders. Other pages keep theory invisible.',
  },
  {
    title: 'Static portfolio vs. deferred theory',
    body: 'HRI, XR, ubicomp, persuasive tech — covered in the course, deliberately not applied here. A static portfolio doesn\'t need an autonomy spectrum or a Fogg model. Theory is parked, indexed, and ready when scope expands.',
  },
];
---

<BaseLayout
  title="HCI — Wing Chun Leung"
  description="ARIN5301 Human-Computer Interaction coursework by Wing Chun Leung at HKUST."
  accent="celadon"
>
  <Header slot="header" />

  <section class="page-hero hci-hero">
    <div class="container content">
      <span class="section-label">ARIN5301</span>
      <h1>Human-Computer<br />Interaction</h1>
      <p class="page-subtitle">
        Coursework from Prof. Xiaojuan Ma's HCI course at HKUST.
        This page applies what it describes.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       ASSIGNMENTS
       H4 (Freedom) — each assignment is deep-linkable
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="assignments-section" aria-label="Course assignments">
    <div class="container content">
      <div class="section-header" data-animate="reveal">
        <span class="section-label">Assignments</span>
        <h2>Coursework</h2>
      </div>

      <div class="assignments-list">
        {assignments.map((assignment) => (
          <article class="assignment-card" data-animate="reveal">
            <div class="assignment-number">{assignment.number}</div>
            <div class="assignment-content">
              <h3 class="assignment-title">{assignment.title}</h3>
              <p class="assignment-description">{assignment.description}</p>
              <div class="assignment-meta">
                <span class="assignment-date">{assignment.date}</span>
                <span class:list={['assignment-status', assignment.status]}>
                  {assignment.status === 'upcoming' ? 'Upcoming' : 'Published'}
                </span>
              </div>
            </div>
          </article>
        ))}
      </div>

      <p class="assignments-note">
        Final project work uploads here on completion.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       SECTION 1 — Core HCI Principles
       Three lenses. Heuristics catch known violations; Gestalt sheds
       cognitive load; Norman keeps emotion, function, and meaning aligned.
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="principles-section" aria-label="Core HCI principles">
    <div class="container">
      <div class="content">
        <span class="section-label">Principles</span>
        <h2>Core HCI Principles</h2>
        <p class="principles-intro">
          Three lenses applied across the site. Heuristics catch known
          violations. Gestalt sheds cognitive load. Norman's three levels
          keep emotion, function, and meaning aligned.
        </p>
      </div>

      <div class="principles-grid">
        {principles.map((group) => (
          <div class="principle-group" data-animate="reveal">
            <h3 class="group-title">{group.category}</h3>
            <ul class="principle-list">
              {group.items.map((item) => (
                <li class="principle-item">
                  <span class="principle-name">{item.name}</span>
                  <span class="principle-desc">{item.description}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       SECTION 2 — Key Insights Applied
       The four refinements from updated lecture material that shaped
       how this site actually behaves.
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="insights-section" aria-label="Key HCI insights applied to this site">
    <div class="container">
      <div class="content">
        <span class="section-label">Insights</span>
        <h2>Key insights applied here</h2>
        <p class="section-lede">
          Beyond the textbook list — four ideas from the course that shape
          how the site actually behaves.
        </p>
      </div>

      <div class="insights-grid">
        {insights.map((item, i) => (
          <article class="insight-card" data-animate="reveal" style={`--delay: ${i * 0.06}s`}>
            <span class="insight-label">{item.label}</span>
            <h3 class="insight-title">{item.title}</h3>
            <p class="insight-body">{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       SECTION 3 — Trade-offs & Limitations
       Every choice gives something and costs something. Naming both keeps
       the design accountable.
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="tradeoffs-section" aria-label="Design trade-offs">
    <div class="container">
      <div class="content">
        <span class="section-label">Trade-offs</span>
        <h2>What we gave up</h2>
        <p class="section-lede">
          Honest about what each choice cost. Theory without trade-offs
          is just slogans.
        </p>
      </div>

      <div class="tradeoff-grid">
        {tradeoffs.map((item, i) => (
          <article class="tradeoff-card" data-animate="reveal" style={`--delay: ${i * 0.06}s`}>
            <h3 class="tradeoff-title">{item.title}</h3>
            <p class="tradeoff-body">{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       SECTION 4 — Design Implications
       From principle to pixel.
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="design-notes-section" aria-label="Design implications">
    <div class="container">
      <div class="section-header" data-animate="reveal">
        <span class="section-label">Implications</span>
        <h2>How principles become pixels</h2>
      </div>

      <div class="design-grid">
        <article class="design-card" data-animate="reveal" style="--delay: 0s">
          <span class="design-icon" aria-hidden="true">&#127912;</span>
          <h3>Color as identity, not signal</h3>
          <p>Vermillion across the site, celadon for /hci. Same pattern, different accent — H1 Consistency through structure, cultural metaphor through tone. Every accent pairs with a text label.</p>
        </article>
        <article class="design-card" data-animate="reveal" style="--delay: 0.08s">
          <span class="design-icon" aria-hidden="true">&#9999;&#65039;</span>
          <h3>Typography as role assignment</h3>
          <p>Cormorant Garamond for emotion, Inter for reading, JetBrains Mono for metadata. Three faces, three jobs — H6 Recognition through visual role, not memorized rule.</p>
        </article>
        <article class="design-card" data-animate="reveal" style="--delay: 0.16s">
          <span class="design-icon" aria-hidden="true">&#9723;&#65039;</span>
          <h3>Whitespace as load shedding</h3>
          <p>96–128px between sections, ≤24px inside cards. Gestalt Proximity does the grouping work so working memory doesn't have to. Content max 720px — eye comfort over real estate.</p>
        </article>
        <article class="design-card" data-animate="reveal" style="--delay: 0.24s">
          <span class="design-icon" aria-hidden="true">&#10024;</span>
          <h3>Motion as feedback, not meaning</h3>
          <p>Reveals confirm content arrived (H7). Staggers bind related items (Common Fate). prefers-reduced-motion zeroes everything — meaning never lives only in animation.</p>
        </article>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* HCI page uses celadon accent */
  .hci-hero {
    background: var(--color-surface);
  }

  .page-hero {
    padding-top: calc(72px + var(--section-gap));
    padding-bottom: var(--space-8);
  }

  .page-hero .section-label {
    opacity: 0;
    transform: translateY(20px);
    animation: pageReveal 0.8s var(--ease-out) 0.2s forwards;
  }

  .page-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    margin-top: var(--space-3);
    margin-bottom: var(--space-3);
    opacity: 0;
    transform: translateY(30px);
    animation: pageReveal 0.8s var(--ease-out) 0.4s forwards;
    background: linear-gradient(135deg, var(--color-ink) 0%, var(--color-celadon) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .page-subtitle {
    color: var(--color-text-secondary);
    max-width: 55ch;
    opacity: 0;
    transform: translateY(20px);
    animation: pageReveal 0.8s var(--ease-out) 0.6s forwards;
  }

  @keyframes pageReveal {
    to { opacity: 1; transform: translateY(0); }
  }

  .section-header {
    margin-bottom: var(--space-5);
    opacity: 0; transform: translateY(30px);
  }
  .section-header.visible {
    opacity: 1; transform: translateY(0);
    transition: opacity 0.8s var(--ease-out), transform 0.8s var(--ease-out);
  }
  .section-header h2 { margin-top: var(--space-2); }

  .section-lede {
    color: var(--color-text-secondary);
    margin-top: var(--space-3);
    max-width: 60ch;
  }

  /* Assignments */
  .assignments-section {
    padding: var(--section-gap) 0;
  }

  .assignments-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .assignment-card {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-celadon);
    border-radius: var(--radius-lg);
    opacity: 0;
    transform: translateY(30px);
    transition: transform var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .assignment-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .assignment-card.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity var(--duration-reveal) var(--ease-out),
                transform var(--duration-reveal) var(--ease-out);
  }

  .assignment-number {
    font-family: var(--font-mono);
    font-size: var(--text-h2);
    color: var(--color-celadon);
    font-weight: var(--weight-medium);
    line-height: 1;
    min-width: 2ch;
  }

  .assignment-title {
    font-size: var(--text-h3);
    margin-bottom: var(--space-1);
  }

  .assignment-description {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2);
  }

  .assignment-meta {
    display: flex;
    gap: var(--space-3);
    align-items: center;
  }

  .assignment-date {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-wash);
  }

  .assignment-status {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  .assignment-status.upcoming {
    color: var(--color-celadon);
    background: rgba(125, 158, 140, 0.1);
  }

  .assignment-status.published {
    color: var(--color-vermillion);
    background: rgba(199, 62, 29, 0.1);
  }

  .assignments-note {
    font-size: var(--text-small);
    color: var(--color-wash);
    font-style: italic;
  }

  /* Section 1 — Principles */
  .principles-section {
    padding: var(--section-gap) 0;
    background: var(--color-surface);
  }

  .principles-section h2 {
    margin-top: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .principles-intro {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
    max-width: 60ch;
  }

  .principles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    max-width: var(--max-container);
  }

  @media (min-width: 768px) {
    .principles-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .principle-group {
    opacity: 0;
    transform: translateY(30px);
  }

  .principle-group.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity var(--duration-reveal) var(--ease-out),
                transform var(--duration-reveal) var(--ease-out);
  }

  .group-title {
    font-size: var(--text-h3);
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  .principle-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .principle-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    transition: background var(--duration-normal) var(--ease-out);
  }

  .principle-item:hover {
    background: rgba(125, 158, 140, 0.06);
  }

  .principle-name {
    font-weight: var(--weight-medium);
    font-size: var(--text-small);
    color: var(--color-celadon);
  }

  .principle-desc {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
  }

  /* Section 2 — Insights */
  .insights-section {
    padding: var(--section-gap) 0;
  }

  .insights-section h2 {
    margin-top: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .insights-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-top: var(--space-6);
  }

  @media (min-width: 768px) {
    .insights-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .insight-card {
    padding: var(--space-5);
    background: var(--color-surface);
    border-left: 2px solid var(--color-celadon);
    border-radius: var(--radius-lg);
    opacity: 0;
    transform: translateY(30px);
    transition: transform var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .insight-card.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                transform var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .insight-card:hover {
    box-shadow: var(--shadow-md);
  }

  .insight-label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-celadon);
    letter-spacing: var(--tracking-wider);
  }

  .insight-title {
    font-size: var(--text-h3);
    margin: var(--space-2) 0 var(--space-3);
  }

  .insight-body {
    color: var(--color-text-secondary);
    font-size: var(--text-small);
    line-height: var(--leading-relaxed);
  }

  /* Section 3 — Trade-offs */
  .tradeoffs-section {
    padding: var(--section-gap) 0;
    background: var(--color-surface);
  }

  .tradeoffs-section h2 {
    margin-top: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .tradeoff-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-top: var(--space-6);
  }

  @media (min-width: 768px) {
    .tradeoff-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .tradeoff-card {
    padding: var(--space-5);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    opacity: 0;
    transform: translateY(30px);
    transition: transform var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .tradeoff-card.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                transform var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .tradeoff-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .tradeoff-title {
    font-size: var(--text-h3);
    margin-bottom: var(--space-3);
  }

  .tradeoff-body {
    color: var(--color-text-secondary);
    font-size: var(--text-small);
    line-height: var(--leading-relaxed);
  }

  /* Section 4 — Design Implications (existing pattern) */
  .design-notes-section {
    padding: var(--section-gap) 0;
  }

  .design-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .design-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .design-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    border-top: 2px solid var(--color-celadon);
    opacity: 0; transform: translateY(30px);
    transition: transform var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .design-card.visible {
    opacity: 1; transform: translateY(0);
    transition: opacity var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                transform var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .design-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .design-icon {
    display: block;
    font-size: 2rem;
    margin-bottom: var(--space-3);
  }

  .design-card h3 {
    font-size: var(--text-h3);
    margin-bottom: var(--space-2);
  }

  .design-card p {
    color: var(--color-text-secondary);
    font-size: var(--text-small);
    line-height: var(--leading-relaxed);
  }

  .design-card code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg);
    padding: 0.1em 0.3em;
    border-radius: var(--radius-sm);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray('[data-animate="reveal"]').forEach((el) => {
    const element = el as HTMLElement;
    gsap.fromTo(element,
      { opacity: 0, y: 40 },
      {
        opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
        scrollTrigger: { trigger: element, start: 'top 85%', toggleActions: 'play none none none' },
      }
    );
  });
</script>
