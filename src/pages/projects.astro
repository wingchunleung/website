---
/**
 * Projects Page — Premium case study style
 * HCI: H6 (Recognition) — metrics visible, company badges, scannable
 * HCI: Gestalt Similarity — consistent card design
 * HCI: Visceral — large metrics create immediate impact
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const projects = [
  {
    title: 'Equity & Options Advisory',
    metric: '4.8/5',
    metricLabel: 'client satisfaction',
    org: 'Carta',
    orgColor: '#1a1a1a',
    period: '2024 — 2025',
    description: 'Advised clients on equity exercises, tender offers, and liquidity events. Redesigned financial modeling and reporting workflows, reducing turnaround from ~30 minutes to seconds. Built automated projection systems for options exercise and tender scenarios.',
    tags: ['Options', 'Financial Modeling', 'Liquidity Events', 'Private Equity'],
    featured: true,
  },
  {
    title: 'AI-Enhanced Investment & Valuation',
    metric: 'RMB 5T+',
    metricLabel: 'AUM scope',
    org: 'HKUST',
    orgColor: '#003366',
    period: '2024 — Present',
    description: 'Enhanced valuation framework using AI and sentiment analysis to identify potential mispricing and investment opportunities. Integrated automated valuation outputs with market signals to support allocation decisions.',
    tags: ['Asset Management', 'Valuation', 'Investment Research'],
    featured: false,
  },
  {
    title: 'Automated Equity Valuation System',
    metric: 'S&P 500',
    metricLabel: 'coverage',
    org: 'HKUST',
    orgColor: '#003366',
    period: '2023 — 2024',
    description: 'Built an automated equity valuation system combining DCF, comparable companies analysis, and hybrid methods. Deployed across S&P 500 companies for daily valuation updates with a scalable refresh pipeline.',
    tags: ['DCF', 'Comps Analysis', 'Equity Valuation', 'Automation'],
    featured: false,
  },
  {
    title: 'Client Reporting & Communication',
    metric: '70%',
    metricLabel: 'faster',
    org: 'Carta',
    orgColor: '#1a1a1a',
    period: '2024 — 2025',
    description: 'Improved client-facing reporting and communication processes for the PE advisory team. Built tools to extract and process financial statements, reducing manual work and improving response quality.',
    tags: ['Client Relations', 'Financial Reporting', 'PE Advisory'],
    featured: false,
  },
  {
    title: 'Financial Controls Automation',
    metric: '40hrs',
    metricLabel: '/month saved',
    org: 'Costco',
    orgColor: '#e31837',
    period: '2023 — 2024',
    description: 'Automated financial processes across reconciliation, journal entries, and audit workflows. Converted multi-step auditing workflows into one-click automated systems using Python and SQL.',
    tags: ['Controls', 'Reconciliation', 'Audit', 'Automation'],
    featured: false,
  },
  {
    title: 'Revenue Accounting Automation',
    metric: '40hrs',
    metricLabel: '/week saved',
    org: 'Costco',
    orgColor: '#e31837',
    period: '2022',
    description: 'Automated reconciliation and journal entry workflows across the revenue accounting team, streamlining manual accounting and control processes.',
    tags: ['Revenue Accounting', 'Controls', 'Process Improvement'],
    featured: false,
  },
];
---

<BaseLayout title="Projects — Wing Chun Leung" description="Selected projects by Wing Chun Leung — LLM systems, financial automation, and process optimization.">
  <Header slot="header" />

  <section class="page-hero">
    <div class="container">
      <span class="section-label">Projects</span>
      <h1>Building smarter<br />financial systems</h1>
      <p class="hero-sub">
        From investment research to financial operations — creating intelligent tools for the finance industry.
      </p>
    </div>
  </section>

  <!-- Featured project — large hero card -->
  {projects.filter(p => p.featured).map((project) => (
    <section class="featured-project" aria-label="Featured project">
      <div class="container">
        <article class="featured-card" data-animate="reveal" style={`--brand: ${project.orgColor}`}>
          <div class="featured-badge">
            <span class="featured-org" style={`color: ${project.orgColor}`}>{project.org}</span>
            <span class="featured-label">Featured</span>
          </div>
          <div class="featured-body">
            <div class="featured-metric-group">
              <span class="featured-metric">{project.metric}</span>
              <span class="featured-metric-label">{project.metricLabel}</span>
            </div>
            <div class="featured-info">
              <h2 class="featured-title">{project.title}</h2>
              <p class="featured-desc">{project.description}</p>
              <div class="featured-tags">
                {project.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        </article>
      </div>
    </section>
  ))}

  <!-- Other projects grid -->
  <section class="projects-grid-section" aria-label="All projects">
    <div class="container">
      <div class="projects-grid">
        {projects.filter(p => !p.featured).map((project, i) => (
          <article class="project-card" data-animate="reveal" style={`--delay: ${i * 0.08}s; --brand: ${project.orgColor}`}>
            <div class="project-card-top">
              <span class="project-org">{project.org}</span>
              <span class="project-period">{project.period}</span>
            </div>
            <div class="project-metric-row">
              <span class="project-metric">{project.metric}</span>
              <span class="project-metric-label">{project.metricLabel}</span>
            </div>
            <h3 class="project-title">{project.title}</h3>
            <p class="project-desc">{project.description}</p>
            <div class="project-tags">
              {project.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-hero {
    padding-top: calc(72px + var(--section-gap));
    padding-bottom: var(--space-6);
  }
  .page-hero .section-label {
    opacity: 0; transform: translateY(20px);
    animation: pr 0.8s var(--ease-out) 0.2s forwards;
  }
  .page-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    margin-top: var(--space-3); margin-bottom: var(--space-3);
    opacity: 0; transform: translateY(30px);
    animation: pr 0.8s var(--ease-out) 0.4s forwards;
    background: linear-gradient(135deg, var(--color-ink) 0%, var(--color-vermillion) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-sub {
    font-size: clamp(1rem, 1.8vw, 1.2rem);
    color: var(--color-wash); max-width: 520px;
    opacity: 0; transform: translateY(20px);
    animation: pr 0.8s var(--ease-out) 0.6s forwards;
  }
  @keyframes pr { to { opacity: 1; transform: translateY(0); } }

  /* ── Featured project hero card ──────────────────────────────────── */
  .featured-project { padding: var(--space-6) 0 var(--section-gap); }

  .featured-card {
    position: relative;
    overflow: hidden;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    border-left: 4px solid var(--brand, var(--color-vermillion));
    opacity: 0; transform: translateY(30px);
  }

  /* Subtle animated gradient shimmer on featured card */
  .featured-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      transparent 30%,
      rgba(199, 62, 29, 0.03) 50%,
      transparent 70%
    );
    background-size: 200% 200%;
    animation: featuredShimmer 6s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes featuredShimmer {
    0%, 100% { background-position: 0% 0%; }
    50% { background-position: 100% 100%; }
  }

  .featured-card.visible {
    opacity: 1; transform: translateY(0);
    transition: opacity 1s var(--ease-out), transform 1s var(--ease-out);
  }

  .featured-badge {
    display: flex; align-items: center; gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .featured-org {
    font-weight: var(--weight-semibold);
    font-size: var(--text-body);
  }

  .featured-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-vermillion);
    padding: 4px 12px;
    border: 1px solid var(--color-vermillion);
    border-radius: 100px;
  }

  .featured-body {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-6);
    align-items: start;
  }

  @media (max-width: 767px) {
    .featured-body { grid-template-columns: 1fr; gap: var(--space-4); }
  }

  .featured-metric-group { text-align: center; }

  .featured-metric {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: var(--weight-light);
    color: var(--color-vermillion);
    line-height: 1;
    display: block;
  }

  .featured-metric-label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-wash);
  }

  .featured-title {
    font-size: var(--text-h2);
    margin-bottom: var(--space-2);
  }

  .featured-desc {
    font-size: var(--text-body);
    color: var(--color-wash);
    margin-bottom: var(--space-3);
    max-width: 55ch;
  }

  /* ── Projects grid ─────────────────────────────────────────────────── */
  .projects-grid-section { padding-bottom: var(--section-gap); }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .projects-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .project-card {
    position: relative;
    overflow: hidden;
    padding: var(--space-5);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    border-top: 3px solid var(--brand, var(--color-border));
    opacity: 0; transform: translateY(30px);
    transition: transform var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  /* Spotlight glow — follows mouse cursor (Stripe-style) */
  .project-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      500px circle at var(--mx, 50%) var(--my, 50%),
      rgba(199, 62, 29, 0.08),
      transparent 40%
    );
    opacity: 0;
    transition: opacity var(--duration-normal) var(--ease-out);
    pointer-events: none;
    z-index: 0;
  }

  .project-card:hover::before { opacity: 1; }

  /* Shimmer sweep */
  .project-card::after {
    content: '';
    position: absolute;
    top: 0; left: -100%; width: 50%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    pointer-events: none; z-index: 1;
  }

  .project-card:hover::after {
    animation: shimmer 0.7s ease-out forwards;
  }

  @keyframes shimmer { to { left: 150%; } }

  .project-card.visible {
    opacity: 1; transform: translateY(0);
    transition: opacity var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                transform var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .project-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08);
    border-color: transparent;
  }

  .project-card-top {
    display: flex; justify-content: space-between;
    align-items: center; margin-bottom: var(--space-3);
  }

  .project-org {
    font-weight: var(--weight-semibold);
    font-size: var(--text-small);
    color: var(--brand, var(--color-text));
  }

  .project-period {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-wash);
  }

  .project-metric-row {
    margin-bottom: var(--space-2);
  }

  .project-metric {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: var(--weight-light);
    color: var(--color-vermillion);
    line-height: 1;
  }

  .project-metric-label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-wash);
    margin-left: 6px;
  }

  .project-title {
    font-size: var(--text-body);
    font-weight: var(--weight-medium);
    margin-bottom: var(--space-2);
  }

  .project-desc {
    font-size: var(--text-small);
    color: var(--color-wash);
    margin-bottom: var(--space-3);
  }

  /* ── Shared tags ───────────────────────────────────────────────────── */
  .featured-tags, .project-tags {
    display: flex; flex-wrap: wrap; gap: var(--space-2);
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: var(--tracking-wide);
    color: var(--color-wash);
    padding: 4px 10px;
    border: 1px solid var(--color-border);
    border-radius: 100px;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // GSAP scroll reveals
  gsap.utils.toArray('[data-animate="reveal"]').forEach((el) => {
    const element = el as HTMLElement;
    const delay = parseFloat(element.style.getPropertyValue('--delay') || '0');
    gsap.fromTo(element,
      { opacity: 0, y: 40 },
      {
        opacity: 1, y: 0, duration: 0.8, delay, ease: 'power3.out',
        scrollTrigger: { trigger: element, start: 'top 85%', toggleActions: 'play none none none' },
      }
    );
  });

  // Spotlight glow on project cards
  document.querySelectorAll('.project-card').forEach((card) => {
    card.addEventListener('pointermove', (e: PointerEvent) => {
      const rect = (card as HTMLElement).getBoundingClientRect();
      (card as HTMLElement).style.setProperty('--mx', `${e.clientX - rect.left}px`);
      (card as HTMLElement).style.setProperty('--my', `${e.clientY - rect.top}px`);
    });
  });
</script>
