---
/**
 * Homepage — Redesigned: Bright, Welcoming, Apple/Carta-quality
 *
 * HCI Principles:
 * - Visceral: Bright, clean, emotionally warm first impression
 * - Behavioral: Clear scroll flow, progressive disclosure
 * - Reflective: "This person cares about craft and welcomes me"
 * - Norman: "Attractive things work better"
 * - H3 (Minimalism): Hero has only greeting + animation, no clutter
 * - H7 (Visibility): Scroll indicator guides next action
 *
 * Structure:
 * 1. Hero: Welcoming animation + "Hey there" (no name)
 * 2. Introduction: Name + bridge tagline
 * 3. Journey: Career story
 * 4. Featured Work: Impact metrics
 * 5. Contact: Clean CTA
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroCanvas from '../components/HeroCanvas.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const journeySteps = [
  {
    label: '01',
    place: 'Hong Kong',
    period: '1999 — 2017',
    heading: 'Where it began',
    accent: '#c73e1d',
    text: 'Born and raised in Hong Kong. A city where East meets West, tradition meets innovation — shaping a perspective that would define everything that followed.',
  },
  {
    label: '02',
    place: 'University of Washington',
    period: '2018 — 2022',
    heading: 'Building the foundation',
    accent: '#4b2e83',
    text: 'From community college (4.0 GPA) to UW, double-majoring in Finance and Information Systems. CFO of the Blockchain Society. Discovering that the most interesting problems live between disciplines.',
  },
  {
    label: '03',
    place: 'Costco Wholesale',
    period: '2023 — 2024',
    heading: 'Systems thinking',
    accent: '#e31837',
    text: 'Turned a 4-hour manual payroll process into a single button click — 99% time reduction. Built forecasting models with 97% accuracy. The best technology disappears into the workflow.',
  },
  {
    label: '04',
    place: 'Carta',
    period: '2024 — 2025',
    heading: 'Scaling impact',
    accent: '#1a1a1a',
    text: 'Redesigned the PE advisory projection workflow, cutting processing time by 70%. Built LLM-powered tools for data extraction. Client satisfaction: 4.8/5.0.',
  },
  {
    label: '05',
    place: 'HKUST',
    period: '2025 — Present',
    heading: 'The synthesis',
    accent: '#003366',
    text: 'Returned to Hong Kong for an MSc in AI. Researching LLM-driven macro allocation — building multi-agent systems that reason about global markets. The bridge between finance and AI, made real.',
  },
];

const featuredWork = [
  {
    title: 'LLM Macro Allocation Pipeline',
    metric: 'RMB 5T+',
    metricLabel: 'AUM scope',
    org: 'HKUST',
    orgColor: '#003366',
    description: 'Multi-agent LLM system for macro cycle analysis and asset allocation.',
    tags: ['AI Research', 'Multi-Agent', 'Finance'],
  },
  {
    title: 'Financial Workflow Automation',
    metric: '70%',
    metricLabel: 'faster',
    org: 'Carta',
    orgColor: '#1a1a1a',
    description: 'Redesigned PE advisory projection workflow, cutting Bloomberg Terminal processing time.',
    tags: ['Process Design', 'LLM', 'Carta'],
  },
  {
    title: 'Payroll System Optimization',
    metric: '99%',
    metricLabel: 'time saved',
    org: 'Costco',
    orgColor: '#e31837',
    description: 'Transformed a 4-hour manual task into a single-click automated process.',
    tags: ['Automation', 'Python', 'SQL'],
  },
];
---

<BaseLayout title="Wing Chun Leung — Finance × AI">
  <Header slot="header" />

  <!-- ═══════════════════════════════════════════════════════════════════
       INTRO OVERLAY — The "brand moment" (plays once, then reveals hero)
       Separate layer above everything. Clip-path iris close reveals page.
       HCI: Visceral — cinematic first impression creates emotional engagement
       ═══════════════════════════════════════════════════════════════════ -->
  <div class="intro-overlay" id="intro-overlay" aria-hidden="true">
    <div class="intro-bg"></div>
    <div class="intro-stage">
      <div class="intro-icon">
        <span class="intro-wave-emoji">👋</span>
      </div>
      <div class="intro-text">
        <span class="intro-line">
          <span class="intro-line-inner">Welcome</span>
        </span>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════
       HERO — Immersive particle network (revealed after intro overlay)
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="hero" aria-label="Welcome">
    <HeroCanvas />

    <div class="hero-content">
      <div class="hero-wave" aria-hidden="true">
        <span class="wave-hand">👋</span>
      </div>

      <h1 class="hero-greeting">
        <span class="greeting-mask">
          <span class="greeting-text">Welcome to my page</span>
        </span>
      </h1>

      <div class="hero-cta-wrap">
        <a href="#intro" class="btn-hero">
          <span>Explore</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M7 1v12M1 7l6 6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="scroll-cue" aria-hidden="true">
      <div class="scroll-line-track">
        <div class="scroll-line-fill"></div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       INTRODUCTION — Name + positioning
       Appears after scroll — builds on the welcome
       ═══════════════════════════════════════════════════════════════════ -->
  <section id="intro" class="intro" aria-label="Introduction">
    <div class="container content">
      <div class="intro-content" data-animate="reveal">
        <p class="intro-greeting">I'm</p>
        <h2 class="intro-name">Wing Chun Leung</h2>
        <div class="intro-divider" aria-hidden="true"></div>
        <p class="intro-tagline">
          Finance speaks one language. AI speaks another.
          <strong>I build the bridge.</strong>
        </p>
        <p class="intro-bio">
          Currently pursuing an MSc in Artificial Intelligence at HKUST, where I research LLM-driven macro allocation. Previously at Carta and Costco, turning complex financial processes into intelligent automated systems.
        </p>
        <div class="intro-actions">
          <a href={`${base}/about`} class="btn-primary">Learn more</a>
          <a href={`${base}/contact`} class="btn-outline">Get in touch</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       EXPERIENCE LOGOS — Visual credibility strip
       HCI: H6 (Recognition) — logos are recognized faster than text
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="logo-strip" aria-label="Experience" data-animate="reveal">
    <div class="container">
      <span class="section-label" style="text-align:center;display:block;margin-bottom:var(--space-4)">Experience</span>
      <div class="logo-row">
        <div class="logo-item">
          <img src={`${base}/logos/hkust.svg`} alt="HKUST" class="logo-img" loading="lazy" width="120" height="24" />
          <span class="logo-role">Research Assistant</span>
        </div>
        <div class="logo-item">
          <img src={`${base}/logos/carta.svg`} alt="Carta" class="logo-img" loading="lazy" width="110" height="28" />
          <span class="logo-role">PE Analyst</span>
        </div>
        <div class="logo-item">
          <img src={`${base}/logos/costco.svg`} alt="Costco Wholesale" class="logo-img" loading="lazy" width="140" height="30" />
          <span class="logo-role">Financial Systems</span>
        </div>
        <div class="logo-item">
          <img src={`${base}/logos/uw.svg`} alt="University of Washington" class="logo-img" loading="lazy" width="36" height="32" />
          <span class="logo-role">BBA Finance & IS</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       MARQUEE — Scrolling text ticker (premium agency signal)
       ═══════════════════════════════════════════════════════════════════ -->
  <div class="marquee-band" aria-hidden="true">
    <div class="marquee-track">
      <span class="marquee-text">Finance</span>
      <span class="marquee-dot"></span>
      <span class="marquee-text">Artificial Intelligence</span>
      <span class="marquee-dot"></span>
      <span class="marquee-text">Systems Design</span>
      <span class="marquee-dot"></span>
      <span class="marquee-text">LLM Research</span>
      <span class="marquee-dot"></span>
      <span class="marquee-text">Multi-Agent Systems</span>
      <span class="marquee-dot"></span>
      <span class="marquee-text">Finance</span>
      <span class="marquee-dot"></span>
      <span class="marquee-text">Artificial Intelligence</span>
      <span class="marquee-dot"></span>
      <span class="marquee-text">Systems Design</span>
      <span class="marquee-dot"></span>
      <span class="marquee-text">LLM Research</span>
      <span class="marquee-dot"></span>
      <span class="marquee-text">Multi-Agent Systems</span>
      <span class="marquee-dot"></span>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════
       JOURNEY — Career story timeline
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="journey" aria-label="Career journey">
    <div class="container">
      <div class="section-header" data-animate="reveal">
        <span class="section-label">The Journey</span>
        <h2>From Hong Kong to<br />the frontier of AI</h2>
      </div>

      <div class="journey-timeline">
        {journeySteps.map((step, i) => (
          <article class="journey-step" data-animate="reveal" style={`--delay: ${i * 0.08}s; --step-accent: ${step.accent}`}>
            <div class="step-marker">
              <span class="step-number">{step.label}</span>
              <div class="step-line" aria-hidden="true"></div>
            </div>
            <div class="step-content">
              <div class="step-meta">
                <span class="step-place">{step.place}</span>
                <span class="step-period">{step.period}</span>
              </div>
              <h3 class="step-heading">{step.heading}</h3>
              <p class="step-text">{step.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       FEATURED WORK — Impact metrics
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="featured-work" aria-label="Featured projects">
    <div class="container">
      <div class="section-header" data-animate="reveal">
        <span class="section-label">Selected Work</span>
        <h2>Things I've built</h2>
      </div>

      <div class="work-grid">
        {featuredWork.map((work, i) => (
          <article class="work-card" data-animate="reveal" style={`--delay: ${i * 0.1}s`}>
            <div class="work-card-header">
              <span class="work-org-badge" style={`--org-color: ${work.orgColor}`}>{work.org}</span>
              <div class="work-metric-group">
                <span class="work-metric">{work.metric}</span>
                <span class="work-metric-label">{work.metricLabel}</span>
              </div>
            </div>
            <h3 class="work-title">{work.title}</h3>
            <p class="work-description">{work.description}</p>
            <div class="work-tags">
              {work.tags.map((tag) => (
                <span class="work-tag">{tag}</span>
              ))}
            </div>
          </article>
        ))}
      </div>

      <div class="section-cta">
        <a href={`${base}/projects`} class="btn-outline">View all projects</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       CONTACT — Clean CTA
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="contact-teaser" aria-label="Get in touch">
    <div class="container content">
      <div class="section-header centered" data-animate="reveal">
        <span class="section-label">Get in Touch</span>
        <h2>Let's connect</h2>
      </div>
      <p class="contact-text" data-animate="reveal">
        Whether you're interested in AI research, fintech, or just want to say hello — I'd love to hear from you.
      </p>
      <div class="contact-actions" data-animate="reveal">
        <a href="mailto:wingchunleung8@gmail.com" class="btn-primary">Say hello</a>
        <a href={`${base}/contact`} class="btn-outline">All contact info</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ══════════════════════════════════════════════════════════════════════
     INTRO OVERLAY — Brand moment layer (plays once, reveals hero)
     ══════════════════════════════════════════════════════════════════════ */

  .intro-overlay {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    will-change: clip-path, opacity;
    clip-path: inset(0 0 0 0);
    animation: introExit 1s cubic-bezier(0.65, 0, 0.35, 1) 2.4s forwards;
  }

  .intro-overlay.finished { display: none; }

  .intro-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      #ffffff 0%,
      #faf9f7 30%,
      rgba(199, 62, 29, 0.03) 60%,
      #faf9f7 80%,
      #ffffff 100%
    );
    background-size: 200% 200%;
    animation: introGradientShift 4s ease-in-out infinite;
  }

  @keyframes introGradientShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .intro-stage {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .intro-icon {
    opacity: 0;
    transform: scale(0.2) rotate(-30deg);
    animation: introIconPop 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s forwards;
  }

  .intro-wave-emoji {
    display: inline-block;
    font-size: clamp(3rem, 6vw, 4.5rem);
    transform-origin: 70% 70%;
    animation: introWaveMotion 0.8s ease-in-out 1s 1;
  }

  .intro-text {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: var(--weight-light);
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .intro-line {
    display: block;
    overflow: hidden;
  }

  .intro-line-inner {
    display: block;
    transform: translateY(120%);
    animation: introTextUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.7s forwards;
  }

  @keyframes introIconPop {
    0% { opacity: 0; transform: scale(0.2) rotate(-30deg); }
    50% { opacity: 1; transform: scale(1.15) rotate(8deg); }
    100% { opacity: 1; transform: scale(1) rotate(0deg); }
  }

  @keyframes introWaveMotion {
    0% { transform: rotate(0deg); }
    15% { transform: rotate(14deg); }
    30% { transform: rotate(-8deg); }
    45% { transform: rotate(14deg); }
    60% { transform: rotate(-4deg); }
    75% { transform: rotate(10deg); }
    100% { transform: rotate(0deg); }
  }

  @keyframes introTextUp {
    from { transform: translateY(120%); }
    to { transform: translateY(0); }
  }

  @keyframes introExit {
    0% { clip-path: inset(0 0 0 0); opacity: 1; }
    60% { clip-path: inset(3% 3% 3% 3% round 24px); opacity: 1; }
    100% { clip-path: inset(50% 50% 50% 50% round 24px); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .intro-overlay { display: none; }
  }

  /* ══════════════════════════════════════════════════════════════════════
     HERO — Full viewport, revealed after intro
     ══════════════════════════════════════════════════════════════════════ */

  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: var(--color-bg);
    overflow: hidden;
    padding: 0 var(--gutter);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 720px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  /* ── Phase 1: Waving hand entrance (0-2s) ────────────────────────── */
  /* Hero elements start animating AFTER intro overlay exits (~2.8s) */
  .hero-wave {
    opacity: 0;
    transform: scale(0.3) rotate(-20deg);
    animation: handEntrance 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 2.8s forwards;
  }

  .wave-hand {
    display: inline-block;
    font-size: clamp(3.5rem, 7vw, 5rem);
    transform-origin: 70% 70%;
    animation: waveMotion 2s ease-in-out 3.6s 2;
  }

  @keyframes handEntrance {
    0% { opacity: 0; transform: scale(0.3) rotate(-20deg); }
    60% { opacity: 1; transform: scale(1.1) rotate(5deg); }
    100% { opacity: 1; transform: scale(1) rotate(0deg); }
  }

  @keyframes waveMotion {
    0% { transform: rotate(0deg); }
    10% { transform: rotate(14deg); }
    20% { transform: rotate(-8deg); }
    30% { transform: rotate(14deg); }
    40% { transform: rotate(-4deg); }
    50% { transform: rotate(10deg); }
    60% { transform: rotate(0deg); }
    100% { transform: rotate(0deg); }
  }

  /* ── Text mask reveal ────────────────────────────────────────────── */
  .hero-greeting {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 6.5vw, 5rem);
    font-weight: var(--weight-light);
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text);
    overflow: hidden;
  }

  .greeting-mask {
    display: block;
    overflow: hidden;
  }

  .greeting-text {
    display: block;
    transform: translateY(110%);
    animation: textReveal 1s cubic-bezier(0.16, 1, 0.3, 1) 3.1s forwards;
  }

  @keyframes textReveal {
    to { transform: translateY(0); }
  }

  /* ── Phase 3: CTA fade in (3s+) ─────────────────────────────────── */
  .hero-cta-wrap {
    opacity: 0;
    transform: translateY(16px);
    animation: ctaReveal 0.8s var(--ease-out) 3.6s forwards;
  }

  @keyframes ctaReveal {
    to { opacity: 1; transform: translateY(0); }
  }

  .btn-hero {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: var(--weight-medium);
    padding: 14px 36px;
    background: var(--color-ink);
    color: var(--color-bg);
    border-radius: 100px;
    text-decoration: none;
    transition: all var(--duration-normal) var(--ease-out);
    min-height: 48px;
    letter-spacing: 0.02em;
  }

  .btn-hero svg {
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .btn-hero:hover {
    background: var(--color-vermillion);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(199, 62, 29, 0.2);
  }

  .btn-hero:hover svg {
    transform: translateY(3px);
  }

  .btn-hero::after { display: none; }

  /* ── Scroll indicator (Apple-style) ─────────────────────────────── */
  .scroll-cue {
    position: absolute;
    bottom: var(--space-5);
    left: 50%;
    transform: translateX(-50%);
    opacity: 0;
    animation: ctaReveal 0.6s var(--ease-out) 4s forwards;
    z-index: 2;
  }

  .scroll-line-track {
    width: 1px;
    height: 60px;
    background: var(--color-border);
    border-radius: 1px;
    overflow: hidden;
  }

  .scroll-line-fill {
    width: 100%;
    height: 30px;
    background: var(--color-vermillion);
    border-radius: 1px;
    animation: scrollLine 2s var(--ease-in-out) infinite 4.5s;
  }

  @keyframes scrollLine {
    0% { transform: translateY(-30px); }
    50% { transform: translateY(60px); }
    100% { transform: translateY(60px); }
  }

  /* ══════════════════════════════════════════════════════════════════════
     INTRODUCTION — Name reveal after scroll
     ══════════════════════════════════════════════════════════════════════ */

  .intro {
    padding: clamp(8rem, 12vw, 12rem) 0;
    background: var(--color-bg);
  }

  .intro-content {
    text-align: center;
    opacity: 0;
    transform: translateY(40px);
  }

  .intro-content.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 1s var(--ease-out),
                transform 1s var(--ease-out);
  }

  .intro-content.visible .intro-divider {
    width: 48px;
  }

  .intro-greeting {
    font-family: var(--font-mono);
    font-size: var(--text-small);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-wash);
    margin-bottom: var(--space-2);
  }

  .intro-name {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: var(--weight-light);
    line-height: 1.02;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-5);
    background: linear-gradient(135deg, var(--color-ink) 0%, var(--color-vermillion) 50%, var(--color-ink) 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: nameGradientShift 4s ease-in-out infinite;
  }

  @keyframes nameGradientShift {
    0%, 100% { background-position: 0% center; }
    50% { background-position: 100% center; }
  }

  .intro-divider {
    width: 0;
    height: 2px;
    background: var(--color-vermillion);
    margin: 0 auto var(--space-5);
    border-radius: 1px;
    transition: width 1s cubic-bezier(0.16, 1, 0.3, 1) 0.3s;
  }

  .intro-tagline {
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    line-height: 1.5;
    color: var(--color-wash);
    max-width: 520px;
    margin: 0 auto var(--space-4);
  }

  .intro-tagline strong {
    color: var(--color-text);
    font-weight: var(--weight-medium);
  }

  .intro-bio {
    font-size: var(--text-body);
    color: var(--color-wash);
    max-width: 560px;
    margin: 0 auto var(--space-5);
    line-height: var(--leading-relaxed);
  }

  .intro-actions {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ══════════════════════════════════════════════════════════════════════
     LOGO STRIP — Visual experience credibility
     ══════════════════════════════════════════════════════════════════════ */

  .logo-strip {
    padding: var(--space-8) 0;
    background: var(--color-bg);
    opacity: 0;
    transform: translateY(30px);
  }

  .logo-strip.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 1s var(--ease-out),
                transform 1s var(--ease-out);
  }

  .logo-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
    flex-wrap: wrap;
  }

  .logo-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .logo-img {
    height: 28px;
    width: auto;
    object-fit: contain;
    opacity: 0.6;
    transition: opacity var(--duration-normal) var(--ease-out);
    filter: grayscale(0.3);
  }

  .logo-item:hover .logo-img {
    opacity: 1;
    filter: grayscale(0);
  }

  .logo-role {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-wash);
  }

  /* ══════════════════════════════════════════════════════════════════════
     MARQUEE — Infinite scrolling text ticker
     ══════════════════════════════════════════════════════════════════════ */

  .marquee-band {
    padding: var(--space-4) 0;
    overflow: hidden;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .marquee-track {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    width: max-content;
    animation: marqueeScroll 25s linear infinite;
  }

  .marquee-text {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 2rem);
    font-weight: var(--weight-light);
    letter-spacing: -0.02em;
    color: var(--color-wash);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .marquee-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-vermillion);
    flex-shrink: 0;
  }

  @keyframes marqueeScroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }

  /* ══════════════════════════════════════════════════════════════════════
     SECTION HEADERS — Reusable pattern
     ══════════════════════════════════════════════════════════════════════ */

  .section-header {
    margin-bottom: var(--space-8);
    opacity: 0;
    transform: translateY(30px);
  }

  .section-header.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.8s var(--ease-out),
                transform 0.8s var(--ease-out);
  }

  .section-header.centered {
    text-align: center;
  }

  .section-header h2 {
    margin-top: var(--space-2);
  }

  /* ══════════════════════════════════════════════════════════════════════
     JOURNEY — Timeline
     ══════════════════════════════════════════════════════════════════════ */

  .journey {
    padding: var(--section-gap) 0;
    background: var(--color-stone);
    position: relative;
  }

  /* Smooth gradient transition from white into grey */
  .journey::before {
    content: '';
    position: absolute;
    top: -60px;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(to bottom, var(--color-bg), var(--color-stone));
    pointer-events: none;
  }

  .journey-timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .journey-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    opacity: 0;
    transform: translateY(40px);
  }

  .journey-step.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                transform var(--duration-reveal) var(--ease-out) var(--delay, 0s);
  }

  .step-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding-top: var(--space-1);
  }

  .step-number {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-bg);
    font-weight: var(--weight-medium);
    background: var(--step-accent, var(--color-vermillion));
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 0 0 4px var(--color-stone), 0 0 0 5px var(--step-accent, var(--color-vermillion));
  }

  .step-line {
    width: 2px;
    flex: 1;
    min-height: 40px;
    background: linear-gradient(to bottom, var(--step-accent, var(--color-border)), var(--color-border));
    border-radius: 1px;
  }

  .step-content {
    max-width: var(--max-content);
    background: var(--color-bg);
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--step-accent, var(--color-vermillion));
    transition: box-shadow var(--duration-normal) var(--ease-out),
                transform var(--duration-normal) var(--ease-out);
  }

  .step-content:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .step-meta {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .step-place {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-text);
    font-weight: var(--weight-medium);
  }

  .step-period {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-wide);
    color: var(--color-wash);
  }

  .step-heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-light);
    margin-bottom: var(--space-2);
  }

  .step-text {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  /* ══════════════════════════════════════════════════════════════════════
     FEATURED WORK — Cards with impact metrics
     ══════════════════════════════════════════════════════════════════════ */

  .featured-work {
    padding: var(--section-gap) 0;
    background: var(--color-bg);
  }

  .work-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  @media (min-width: 768px) {
    .work-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .work-card {
    position: relative;
    overflow: hidden;
    background: var(--color-stone);
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    transition: transform var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
    opacity: 0;
    transform: translateY(40px);
  }

  .work-card.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                transform var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .work-card:hover {
    transform: translateY(-6px) perspective(800px) rotateY(var(--tilt-x, 0deg)) rotateX(var(--tilt-y, 0deg));
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08);
  }

  /* Spotlight dim: siblings dim when one card is hovered */
  .work-grid.hovering .work-card:not(:hover) {
    opacity: 0.55;
    filter: saturate(0.7);
  }

  .work-card {
    transition: transform var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out),
                opacity 0.4s var(--ease-out),
                filter 0.4s var(--ease-out);
  }

  /* Premium shine sweep on hover */
  .work-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -75%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.3),
      transparent
    );
    transition: left 0.6s var(--ease-out);
    pointer-events: none;
  }

  .work-card:hover::before {
    left: 125%;
  }

  .work-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-3);
  }

  .work-org-badge {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.02em;
    color: var(--org-color, var(--color-text));
    padding: 6px 14px;
    border: 1.5px solid var(--org-color, var(--color-border));
    border-radius: 100px;
    white-space: nowrap;
  }

  .work-metric-group {
    text-align: right;
  }

  .work-metric {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: var(--weight-light);
    color: var(--color-vermillion);
    line-height: 1;
    display: block;
  }

  .work-metric-label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-wash);
  }

  .work-title {
    font-size: var(--text-h3);
    margin-bottom: var(--space-2);
  }

  .work-description {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-3);
  }

  .work-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .work-tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: var(--tracking-wide);
    color: var(--color-wash);
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .section-cta {
    text-align: center;
  }

  /* ══════════════════════════════════════════════════════════════════════
     CONTACT TEASER
     ══════════════════════════════════════════════════════════════════════ */

  .contact-teaser {
    padding: var(--section-gap) 0;
    background: var(--color-stone);
    text-align: center;
    position: relative;
  }

  .contact-teaser::before {
    content: '';
    position: absolute;
    top: -60px;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(to bottom, var(--color-bg), var(--color-stone));
    pointer-events: none;
  }

  .contact-text {
    color: var(--color-text-secondary);
    margin-inline: auto;
    margin-bottom: var(--space-5);
    max-width: 480px;
    opacity: 0;
    transform: translateY(20px);
  }

  .contact-text.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.8s var(--ease-out) 0.1s,
                transform 0.8s var(--ease-out) 0.1s;
  }

  .contact-actions {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(20px);
  }

  .contact-actions.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.8s var(--ease-out) 0.2s,
                transform 0.8s var(--ease-out) 0.2s;
  }

  /* ══════════════════════════════════════════════════════════════════════
     BUTTONS
     ══════════════════════════════════════════════════════════════════════ */

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: var(--weight-medium);
    padding: 14px 32px;
    background: var(--color-ink);
    color: var(--color-bg);
    border-radius: 100px;
    text-decoration: none;
    transition: background var(--duration-normal) var(--ease-out),
                transform var(--duration-fast) var(--ease-out);
    min-height: 48px;
  }

  .btn-primary:hover {
    background: var(--color-vermillion);
    transform: translateY(-1px);
  }

  .btn-primary::after { display: none; }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: var(--weight-medium);
    padding: 14px 32px;
    border: 1.5px solid var(--color-border);
    color: var(--color-text);
    border-radius: 100px;
    text-decoration: none;
    transition: border-color var(--duration-normal) var(--ease-out),
                color var(--duration-normal) var(--ease-out),
                transform var(--duration-fast) var(--ease-out);
    min-height: 48px;
  }

  .btn-outline:hover {
    border-color: var(--color-ink);
    transform: translateY(-1px);
  }

  .btn-outline::after { display: none; }
</style>

<script>
  // ── Intro overlay: show once per session, then remove ──
  const overlay = document.getElementById('intro-overlay');
  if (overlay) {
    if (sessionStorage.getItem('intro-seen')) {
      // Skip intro on return visits within session
      overlay.remove();
      document.querySelectorAll('.hero-wave, .greeting-text, .hero-cta-wrap, .scroll-cue').forEach(el => {
        (el as HTMLElement).style.animation = 'none';
        (el as HTMLElement).style.opacity = '1';
        (el as HTMLElement).style.transform = 'none';
      });
    } else {
      sessionStorage.setItem('intro-seen', '1');
      overlay.addEventListener('animationend', (e: AnimationEvent) => {
        if (e.animationName === 'introExit') {
          overlay.classList.add('finished');
          setTimeout(() => overlay.remove(), 200);
        }
      });
    }
  }

  // ── GSAP ScrollTrigger for premium scroll reveals ──
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Reveal all [data-animate="reveal"] elements with GSAP
  gsap.utils.toArray('[data-animate="reveal"]').forEach((el) => {
    const element = el as HTMLElement;
    const delay = parseFloat(element.style.getPropertyValue('--delay') || '0');

    gsap.fromTo(element,
      { opacity: 0, y: 40 },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        delay,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: element,
          start: 'top 85%',
          toggleActions: 'play none none none',
        },
      }
    );
  });

  // Animate intro divider expansion
  const divider = document.querySelector('.intro-divider');
  if (divider) {
    gsap.fromTo(divider,
      { width: 0 },
      {
        width: 48,
        duration: 1,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.intro-content',
          start: 'top 75%',
        },
      }
    );
  }

  // ── Staggered journey steps ──
  const journeySteps = gsap.utils.toArray('.journey-step');
  if (journeySteps.length > 0) {
    journeySteps.forEach((step, i) => {
      gsap.fromTo(step as HTMLElement,
        { opacity: 0, x: -30 },
        {
          opacity: 1, x: 0, duration: 0.8, delay: i * 0.08, ease: 'power3.out',
          scrollTrigger: { trigger: step as HTMLElement, start: 'top 85%' },
        }
      );
    });
  }

  // ── Animated metric counters on work cards ──
  document.querySelectorAll('.work-metric').forEach((el) => {
    const raw = (el as HTMLElement).textContent?.trim() || '';
    const match = raw.match(/^([^\d]*)([\d,.]+)(.*)$/);
    if (!match) return;
    const prefix = match[1];
    const target = parseFloat(match[2].replace(/,/g, ''));
    const suffix = match[3];
    const hasDecimal = match[2].includes('.');
    const decimals = hasDecimal ? match[2].split('.')[1].length : 0;

    const counter = { val: 0 };
    ScrollTrigger.create({
      trigger: el as HTMLElement,
      start: 'top 85%',
      once: true,
      onEnter: () => {
        gsap.to(counter, {
          val: target,
          duration: 2,
          ease: 'power2.out',
          onUpdate: () => {
            const formatted = hasDecimal ? counter.val.toFixed(decimals) : Math.round(counter.val).toString();
            (el as HTMLElement).textContent = `${prefix}${formatted}${suffix}`;
          },
        });
      },
    });
  });

  // ── Spotlight dim siblings on work grid hover ──
  const workGrid = document.querySelector('.work-grid');
  if (workGrid) {
    workGrid.addEventListener('mouseenter', () => workGrid.classList.add('hovering'));
    workGrid.addEventListener('mouseleave', () => workGrid.classList.remove('hovering'));
  }

  // ── Staggered logo strip entrance ──
  const logoItems = gsap.utils.toArray('.logo-item');
  if (logoItems.length > 0) {
    gsap.fromTo(logoItems,
      { opacity: 0, y: 30 },
      {
        opacity: 1, y: 0, duration: 0.6, stagger: 0.1, ease: 'power3.out',
        scrollTrigger: { trigger: '.logo-strip', start: 'top 80%' },
      }
    );
  }

  // ── Hero parallax: fade + translate as user scrolls past ──
  const heroContent = document.querySelector('.hero-content') as HTMLElement;
  if (heroContent) {
    gsap.to(heroContent, {
      opacity: 0,
      y: -60,
      ease: 'none',
      scrollTrigger: {
        trigger: '.hero',
        start: 'top top',
        end: 'bottom top',
        scrub: 0.3,
      },
    });
  }

  // ── 3D tilt on work cards (desktop only) ──
  if (window.innerWidth >= 768) {
    document.querySelectorAll('.work-card').forEach((card) => {
      card.addEventListener('pointermove', (e: PointerEvent) => {
        const el = card as HTMLElement;
        const rect = el.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        el.style.setProperty('--tilt-x', `${x * 6}deg`);
        el.style.setProperty('--tilt-y', `${-y * 6}deg`);
      });
      card.addEventListener('pointerleave', () => {
        const el = card as HTMLElement;
        el.style.setProperty('--tilt-x', '0deg');
        el.style.setProperty('--tilt-y', '0deg');
      });
    });

    // ── Magnetic button effect (desktop only) ──
    document.querySelectorAll('.btn-hero, .btn-primary').forEach((btn) => {
      const el = btn as HTMLElement;
      el.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = el.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        el.style.transform = `translate(${x * 0.12}px, ${y * 0.12}px)`;
      });
      el.addEventListener('mouseleave', () => {
        el.style.transform = '';
        el.style.transition = 'transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1)';
        setTimeout(() => { el.style.transition = ''; }, 500);
      });
    });
  }
</script>
