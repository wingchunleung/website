---
/**
 * Homepage — Redesigned: Bright, Welcoming, Apple/Carta-quality
 *
 * HCI Principles:
 * - Visceral: Bright, clean, emotionally warm first impression
 * - Behavioral: Clear scroll flow, progressive disclosure
 * - Reflective: "This person cares about craft and welcomes me"
 * - Norman: "Attractive things work better"
 * - H3 (Minimalism): Hero has only greeting + animation, no clutter
 * - H7 (Visibility): Scroll indicator guides next action
 *
 * Structure:
 * 1. Hero: Welcoming animation + "Hey there" (no name)
 * 2. Introduction: Name + bridge tagline
 * 3. Journey: Career story
 * 4. Featured Work: Impact metrics
 * 5. Contact: Clean CTA
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const journeySteps = [
  {
    label: '01',
    place: 'Hong Kong',
    period: '1999 — 2017',
    heading: 'Where it began',
    text: 'Born and raised in Hong Kong. A city where East meets West, tradition meets innovation — shaping a perspective that would define everything that followed.',
  },
  {
    label: '02',
    place: 'Washington, USA',
    period: '2018 — 2022',
    heading: 'Building the foundation',
    text: 'From community college with a 4.0 GPA to the University of Washington, double-majoring in Finance and Information Systems. Leading the Blockchain Society as CFO, tutoring peers, and discovering that the most interesting problems live between disciplines.',
  },
  {
    label: '03',
    place: 'Costco Wholesale',
    period: '2023 — 2024',
    heading: 'Systems thinking',
    text: 'Turned a 4-hour manual payroll process into a single button click using Python and SQL — a 99% time reduction. Built forecasting models with 97% accuracy. Learned that the best technology disappears into the workflow.',
  },
  {
    label: '04',
    place: 'Carta',
    period: '2024 — 2025',
    heading: 'Scaling impact',
    text: 'Redesigned the financial projection workflow from Bloomberg Terminal to Google Sheets, cutting processing time by 70%. Built LLM-powered tools for data extraction and client communication. Client satisfaction: 4.8/5.0.',
  },
  {
    label: '05',
    place: 'HKUST',
    period: '2025 — Present',
    heading: 'The synthesis',
    text: 'Returned to Hong Kong for an MSc in Artificial Intelligence. Now researching LLM-driven macro allocation — building multi-agent systems that reason about global markets. The bridge between finance and AI, made real.',
  },
];

const featuredWork = [
  {
    title: 'LLM Macro Allocation Pipeline',
    metric: 'RMB 5T+',
    metricLabel: 'AUM scope',
    description: 'Multi-agent LLM system for macro cycle analysis and asset allocation. Research at HKUST Business School.',
    tags: ['AI Research', 'Multi-Agent', 'Finance'],
  },
  {
    title: 'Financial Workflow Automation',
    metric: '70%',
    metricLabel: 'faster',
    description: 'Redesigned Carta\'s PE advisory projection workflow, replacing Bloomberg Terminal processes with automated pipelines.',
    tags: ['Process Design', 'LLM', 'Carta'],
  },
  {
    title: 'Payroll System Optimization',
    metric: '99%',
    metricLabel: 'time saved',
    description: 'Transformed a 4-hour manual payroll task into a single-click automated process using Python and SQL at Costco.',
    tags: ['Automation', 'Python', 'SQL'],
  },
];
---

<BaseLayout title="Wing Chun Leung — Finance × AI">
  <Header slot="header" />

  <!-- ═══════════════════════════════════════════════════════════════════
       HERO — Welcoming, bright, animated
       First impression = welcome + warmth + personality
       NO name on first screen — visitors already know who this is
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="hero" aria-label="Welcome">
    <div class="hero-content">
      <!-- Animated waving hand -->
      <div class="wave-container" aria-hidden="true">
        <span class="wave-emoji">👋</span>
      </div>

      <h1 class="hero-greeting">
        <span class="greeting-line greeting-line-1">Hey there,</span>
        <span class="greeting-line greeting-line-2">welcome to my corner</span>
        <span class="greeting-line greeting-line-3">of the internet.</span>
      </h1>

      <p class="hero-subtitle">
        Grab a seat. Look around. Stay a while.
      </p>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-cue" aria-hidden="true">
      <span class="scroll-text">Scroll to explore</span>
      <div class="scroll-arrow">
        <svg width="16" height="24" viewBox="0 0 16 24" fill="none" aria-hidden="true">
          <path d="M8 0v20M1 15l7 7 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       INTRODUCTION — Name + positioning
       Appears after scroll — builds on the welcome
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="intro" aria-label="Introduction">
    <div class="container content">
      <div class="intro-content" data-animate="reveal">
        <p class="intro-greeting">I'm</p>
        <h2 class="intro-name">Wing Chun Leung</h2>
        <div class="intro-divider" aria-hidden="true"></div>
        <p class="intro-tagline">
          Finance speaks one language. AI speaks another.
          <strong>I build the bridge.</strong>
        </p>
        <p class="intro-bio">
          Currently pursuing an MSc in Artificial Intelligence at HKUST, where I research LLM-driven macro allocation. Previously at Carta and Costco, turning complex financial processes into intelligent automated systems.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       JOURNEY — Career story timeline
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="journey" aria-label="Career journey">
    <div class="container">
      <div class="section-header" data-animate="reveal">
        <span class="section-label">The Journey</span>
        <h2>From Hong Kong to<br />the frontier of AI</h2>
      </div>

      <div class="journey-timeline">
        {journeySteps.map((step, i) => (
          <article class="journey-step" data-animate="reveal" style={`--delay: ${i * 0.08}s`}>
            <div class="step-marker">
              <span class="step-number">{step.label}</span>
              <div class="step-line" aria-hidden="true"></div>
            </div>
            <div class="step-content">
              <div class="step-meta">
                <span class="step-place">{step.place}</span>
                <span class="step-period">{step.period}</span>
              </div>
              <h3 class="step-heading">{step.heading}</h3>
              <p class="step-text">{step.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       FEATURED WORK — Impact metrics
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="featured-work" aria-label="Featured projects">
    <div class="container">
      <div class="section-header" data-animate="reveal">
        <span class="section-label">Selected Work</span>
        <h2>Things I've built</h2>
      </div>

      <div class="work-grid">
        {featuredWork.map((work, i) => (
          <article class="work-card" data-animate="reveal" style={`--delay: ${i * 0.1}s`}>
            <div class="work-metric-group">
              <span class="work-metric">{work.metric}</span>
              <span class="work-metric-label">{work.metricLabel}</span>
            </div>
            <h3 class="work-title">{work.title}</h3>
            <p class="work-description">{work.description}</p>
            <div class="work-tags">
              {work.tags.map((tag) => (
                <span class="work-tag">{tag}</span>
              ))}
            </div>
          </article>
        ))}
      </div>

      <div class="section-cta">
        <a href="/projects" class="btn-outline">View all projects</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       CONTACT — Clean CTA
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="contact-teaser" aria-label="Get in touch">
    <div class="container content">
      <div class="section-header centered" data-animate="reveal">
        <span class="section-label">Get in Touch</span>
        <h2>Let's connect</h2>
      </div>
      <p class="contact-text" data-animate="reveal">
        Whether you're interested in AI research, fintech, or just want to say hello — I'd love to hear from you.
      </p>
      <div class="contact-actions" data-animate="reveal">
        <a href="mailto:wingchunleung8@gmail.com" class="btn-primary">Say hello</a>
        <a href="/contact" class="btn-outline">All contact info</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ══════════════════════════════════════════════════════════════════════
     HERO — Full viewport, bright, welcoming
     ══════════════════════════════════════════════════════════════════════ */

  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: var(--color-bg);
    overflow: hidden;
    padding: 0 var(--gutter);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 680px;
  }

  /* Waving hand animation */
  .wave-container {
    margin-bottom: var(--space-5);
  }

  .wave-emoji {
    display: inline-block;
    font-size: clamp(3rem, 6vw, 4.5rem);
    animation: wave 2.5s ease-in-out infinite;
    transform-origin: 70% 70%;
    will-change: transform;
  }

  @keyframes wave {
    0% { transform: rotate(0deg); }
    10% { transform: rotate(14deg); }
    20% { transform: rotate(-8deg); }
    30% { transform: rotate(14deg); }
    40% { transform: rotate(-4deg); }
    50% { transform: rotate(10deg); }
    60% { transform: rotate(0deg); }
    100% { transform: rotate(0deg); }
  }

  /* Greeting text — staggered reveal */
  .hero-greeting {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: var(--weight-light);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .greeting-line {
    display: block;
    opacity: 0;
    transform: translateY(30px);
    animation: greetingReveal 0.8s var(--ease-out) forwards;
  }

  .greeting-line-1 { animation-delay: 0.2s; }
  .greeting-line-2 { animation-delay: 0.4s; }
  .greeting-line-3 { animation-delay: 0.6s; }

  @keyframes greetingReveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-wash);
    opacity: 0;
    animation: greetingReveal 0.6s var(--ease-out) 1s forwards;
  }

  /* Scroll cue */
  .scroll-cue {
    position: absolute;
    bottom: var(--space-6);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    opacity: 0;
    animation: greetingReveal 0.5s var(--ease-out) 1.4s forwards;
  }

  .scroll-text {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-wash);
  }

  .scroll-arrow {
    color: var(--color-border);
    animation: scrollBounce 2s var(--ease-in-out) infinite;
  }

  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ══════════════════════════════════════════════════════════════════════
     INTRODUCTION — Name reveal after scroll
     ══════════════════════════════════════════════════════════════════════ */

  .intro {
    padding: var(--section-gap) 0;
    background: var(--color-bg);
  }

  .intro-content {
    text-align: center;
    opacity: 0;
    transform: translateY(40px);
  }

  .intro-content.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 1s var(--ease-out),
                transform 1s var(--ease-out);
  }

  .intro-greeting {
    font-family: var(--font-mono);
    font-size: var(--text-small);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-wash);
    margin-bottom: var(--space-2);
  }

  .intro-name {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: var(--weight-light);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-5);
  }

  .intro-divider {
    width: 48px;
    height: 2px;
    background: var(--color-vermillion);
    margin: 0 auto var(--space-5);
    border-radius: 1px;
  }

  .intro-tagline {
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    line-height: 1.5;
    color: var(--color-wash);
    max-width: 520px;
    margin: 0 auto var(--space-4);
  }

  .intro-tagline strong {
    color: var(--color-text);
    font-weight: var(--weight-medium);
  }

  .intro-bio {
    font-size: var(--text-body);
    color: var(--color-wash);
    max-width: 560px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  /* ══════════════════════════════════════════════════════════════════════
     SECTION HEADERS — Reusable pattern
     ══════════════════════════════════════════════════════════════════════ */

  .section-header {
    margin-bottom: var(--space-8);
    opacity: 0;
    transform: translateY(30px);
  }

  .section-header.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.8s var(--ease-out),
                transform 0.8s var(--ease-out);
  }

  .section-header.centered {
    text-align: center;
  }

  .section-header h2 {
    margin-top: var(--space-2);
  }

  /* ══════════════════════════════════════════════════════════════════════
     JOURNEY — Timeline
     ══════════════════════════════════════════════════════════════════════ */

  .journey {
    padding: var(--section-gap) 0;
    background: var(--color-stone);
  }

  .journey-timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .journey-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    opacity: 0;
    transform: translateY(40px);
  }

  .journey-step.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                transform var(--duration-reveal) var(--ease-out) var(--delay, 0s);
  }

  .step-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding-top: var(--space-1);
  }

  .step-number {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-vermillion);
    font-weight: var(--weight-medium);
  }

  .step-line {
    width: 1px;
    flex: 1;
    min-height: 40px;
    background: var(--color-border);
  }

  .step-content {
    max-width: var(--max-content);
  }

  .step-meta {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .step-place {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-text);
    font-weight: var(--weight-medium);
  }

  .step-period {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-wide);
    color: var(--color-wash);
  }

  .step-heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-light);
    margin-bottom: var(--space-2);
  }

  .step-text {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  /* ══════════════════════════════════════════════════════════════════════
     FEATURED WORK — Cards with impact metrics
     ══════════════════════════════════════════════════════════════════════ */

  .featured-work {
    padding: var(--section-gap) 0;
    background: var(--color-bg);
  }

  .work-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  @media (min-width: 768px) {
    .work-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .work-card {
    background: var(--color-stone);
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    transition: transform var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
    opacity: 0;
    transform: translateY(40px);
  }

  .work-card.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                transform var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .work-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .work-metric-group {
    margin-bottom: var(--space-3);
  }

  .work-metric {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: var(--weight-light);
    color: var(--color-vermillion);
    line-height: 1;
    display: block;
  }

  .work-metric-label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-wash);
  }

  .work-title {
    font-size: var(--text-h3);
    margin-bottom: var(--space-2);
  }

  .work-description {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-3);
  }

  .work-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .work-tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: var(--tracking-wide);
    color: var(--color-wash);
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .section-cta {
    text-align: center;
  }

  /* ══════════════════════════════════════════════════════════════════════
     CONTACT TEASER
     ══════════════════════════════════════════════════════════════════════ */

  .contact-teaser {
    padding: var(--section-gap) 0;
    background: var(--color-stone);
    text-align: center;
  }

  .contact-text {
    color: var(--color-text-secondary);
    margin-inline: auto;
    margin-bottom: var(--space-5);
    max-width: 480px;
    opacity: 0;
    transform: translateY(20px);
  }

  .contact-text.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.8s var(--ease-out) 0.1s,
                transform 0.8s var(--ease-out) 0.1s;
  }

  .contact-actions {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(20px);
  }

  .contact-actions.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.8s var(--ease-out) 0.2s,
                transform 0.8s var(--ease-out) 0.2s;
  }

  /* ══════════════════════════════════════════════════════════════════════
     BUTTONS
     ══════════════════════════════════════════════════════════════════════ */

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: var(--weight-medium);
    padding: 14px 32px;
    background: var(--color-ink);
    color: var(--color-bg);
    border-radius: 100px;
    text-decoration: none;
    transition: background var(--duration-normal) var(--ease-out),
                transform var(--duration-fast) var(--ease-out);
    min-height: 48px;
  }

  .btn-primary:hover {
    background: var(--color-vermillion);
    transform: translateY(-1px);
  }

  .btn-primary::after { display: none; }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: var(--weight-medium);
    padding: 14px 32px;
    border: 1.5px solid var(--color-border);
    color: var(--color-text);
    border-radius: 100px;
    text-decoration: none;
    transition: border-color var(--duration-normal) var(--ease-out),
                color var(--duration-normal) var(--ease-out),
                transform var(--duration-fast) var(--ease-out);
    min-height: 48px;
  }

  .btn-outline:hover {
    border-color: var(--color-ink);
    transform: translateY(-1px);
  }

  .btn-outline::after { display: none; }

  @media (prefers-color-scheme: dark) {
    .btn-primary {
      background: #f5f5f7;
      color: #1d1d1f;
    }
    .btn-primary:hover {
      background: var(--color-vermillion);
      color: #fff;
    }
  }
</style>

<script>
  // Scroll-reveal animation
  const revealElements = document.querySelectorAll('[data-animate="reveal"]');
  if (revealElements.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -8% 0px' }
    );
    revealElements.forEach((el) => observer.observe(el));
  }
</script>
