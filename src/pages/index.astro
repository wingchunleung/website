---
/**
 * Homepage — Redesigned: Bright, Welcoming, Apple/Carta-quality
 *
 * HCI Principles:
 * - Visceral: Bright, clean, emotionally warm first impression
 * - Behavioral: Clear scroll flow, progressive disclosure
 * - Reflective: "This person cares about craft and welcomes me"
 * - Norman: "Attractive things work better"
 * - H3 (Minimalism): Hero has only greeting + animation, no clutter
 * - H7 (Visibility): Scroll indicator guides next action
 *
 * Structure:
 * 1. Hero: Welcoming animation + "Hey there" (no name)
 * 2. Introduction: Name + bridge tagline
 * 3. Journey: Career story
 * 4. Featured Work: Impact metrics
 * 5. Contact: Clean CTA
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroCanvas from '../components/HeroCanvas.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const journeySteps = [
  {
    label: '01',
    place: 'Hong Kong',
    period: '1999 — 2017',
    heading: 'Where it began',
    accent: '#c73e1d',
    text: 'Born and raised in Hong Kong. A city where East meets West, tradition meets innovation — shaping a perspective that would define everything that followed.',
  },
  {
    label: '02',
    place: 'University of Washington',
    period: '2018 — 2022',
    heading: 'Building the foundation',
    accent: '#4b2e83',
    text: 'From community college (4.0 GPA) to UW, double-majoring in Finance and Information Systems. CFO of the Blockchain Society. Discovering that the most interesting problems live between disciplines.',
  },
  {
    label: '03',
    place: 'Costco Wholesale',
    period: '2023 — 2024',
    heading: 'Systems thinking',
    accent: '#e31837',
    text: 'Turned a 4-hour manual payroll process into a single button click — 99% time reduction. Built forecasting models with 97% accuracy. The best technology disappears into the workflow.',
  },
  {
    label: '04',
    place: 'Carta',
    period: '2024 — 2025',
    heading: 'Scaling impact',
    accent: '#1a1a1a',
    text: 'Redesigned the PE advisory projection workflow, cutting processing time by 70%. Built LLM-powered tools for data extraction. Client satisfaction: 4.8/5.0.',
  },
  {
    label: '05',
    place: 'HKUST',
    period: '2025 — Present',
    heading: 'The synthesis',
    accent: '#003366',
    text: 'Returned to Hong Kong for an MSc in AI. Researching LLM-driven macro allocation — building multi-agent systems that reason about global markets. The bridge between finance and AI, made real.',
  },
];

const featuredWork = [
  {
    title: 'LLM Macro Allocation Pipeline',
    metric: 'RMB 5T+',
    metricLabel: 'AUM scope',
    org: 'HKUST',
    orgColor: '#003366',
    description: 'Multi-agent LLM system for macro cycle analysis and asset allocation.',
    tags: ['AI Research', 'Multi-Agent', 'Finance'],
  },
  {
    title: 'Financial Workflow Automation',
    metric: '70%',
    metricLabel: 'faster',
    org: 'Carta',
    orgColor: '#1a1a1a',
    description: 'Redesigned PE advisory projection workflow, cutting Bloomberg Terminal processing time.',
    tags: ['Process Design', 'LLM', 'Carta'],
  },
  {
    title: 'Payroll System Optimization',
    metric: '99%',
    metricLabel: 'time saved',
    org: 'Costco',
    orgColor: '#e31837',
    description: 'Transformed a 4-hour manual task into a single-click automated process.',
    tags: ['Automation', 'Python', 'SQL'],
  },
];
---

<BaseLayout title="Wing Chun Leung — Finance × AI">
  <Header slot="header" />

  <!-- ═══════════════════════════════════════════════════════════════════
       HERO — Immersive, premium, animated particle network
       Full-screen canvas with flowing data-network effect
       Text overlay: welcoming message, no name
       HCI: Visceral level — immediate emotional engagement through motion
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="hero" aria-label="Welcome">
    <!-- Animated particle network background -->
    <HeroCanvas />

    <div class="hero-content">
      <!-- Phase 1: Waving hand entrance -->
      <div class="hero-wave" aria-hidden="true">
        <span class="wave-hand">👋</span>
      </div>

      <!-- Phase 2: Greeting text with mask reveal -->
      <h1 class="hero-greeting">
        <span class="greeting-mask">
          <span class="greeting-text greeting-1">Welcome to my page</span>
        </span>
      </h1>

      <!-- Phase 3: Explore CTA -->
      <div class="hero-cta-wrap">
        <a href="#intro" class="btn-hero">
          <span>Explore</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M7 1v12M1 7l6 6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-cue" aria-hidden="true">
      <div class="scroll-line-track">
        <div class="scroll-line-fill"></div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       INTRODUCTION — Name + positioning
       Appears after scroll — builds on the welcome
       ═══════════════════════════════════════════════════════════════════ -->
  <section id="intro" class="intro" aria-label="Introduction">
    <div class="container content">
      <div class="intro-content" data-animate="reveal">
        <p class="intro-greeting">I'm</p>
        <h2 class="intro-name">Wing Chun Leung</h2>
        <div class="intro-divider" aria-hidden="true"></div>
        <p class="intro-tagline">
          Finance speaks one language. AI speaks another.
          <strong>I build the bridge.</strong>
        </p>
        <p class="intro-bio">
          Currently pursuing an MSc in Artificial Intelligence at HKUST, where I research LLM-driven macro allocation. Previously at Carta and Costco, turning complex financial processes into intelligent automated systems.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       EXPERIENCE LOGOS — Visual credibility strip
       HCI: H6 (Recognition) — logos are recognized faster than text
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="logo-strip" aria-label="Experience" data-animate="reveal">
    <div class="container">
      <span class="section-label" style="text-align:center;display:block;margin-bottom:var(--space-4)">Experience</span>
      <div class="logo-row">
        <div class="logo-item">
          <span class="logo-text-mark" style="--brand: #003366">HKUST</span>
          <span class="logo-role">Research Assistant</span>
        </div>
        <div class="logo-item">
          <span class="logo-text-mark" style="--brand: #1a1a1a">carta</span>
          <span class="logo-role">PE Analyst</span>
        </div>
        <div class="logo-item">
          <span class="logo-text-mark" style="--brand: #e31837">COSTCO</span>
          <span class="logo-role">Financial Systems</span>
        </div>
        <div class="logo-item">
          <span class="logo-text-mark" style="--brand: #4b2e83">UW</span>
          <span class="logo-role">BBA Finance & IS</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       JOURNEY — Career story timeline
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="journey" aria-label="Career journey">
    <div class="container">
      <div class="section-header" data-animate="reveal">
        <span class="section-label">The Journey</span>
        <h2>From Hong Kong to<br />the frontier of AI</h2>
      </div>

      <div class="journey-timeline">
        {journeySteps.map((step, i) => (
          <article class="journey-step" data-animate="reveal" style={`--delay: ${i * 0.08}s; --step-accent: ${step.accent}`}>
            <div class="step-marker">
              <span class="step-number">{step.label}</span>
              <div class="step-line" aria-hidden="true"></div>
            </div>
            <div class="step-content">
              <div class="step-meta">
                <span class="step-place">{step.place}</span>
                <span class="step-period">{step.period}</span>
              </div>
              <h3 class="step-heading">{step.heading}</h3>
              <p class="step-text">{step.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       FEATURED WORK — Impact metrics
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="featured-work" aria-label="Featured projects">
    <div class="container">
      <div class="section-header" data-animate="reveal">
        <span class="section-label">Selected Work</span>
        <h2>Things I've built</h2>
      </div>

      <div class="work-grid">
        {featuredWork.map((work, i) => (
          <article class="work-card" data-animate="reveal" style={`--delay: ${i * 0.1}s`}>
            <div class="work-card-header">
              <span class="work-org-badge" style={`--org-color: ${work.orgColor}`}>{work.org}</span>
              <div class="work-metric-group">
                <span class="work-metric">{work.metric}</span>
                <span class="work-metric-label">{work.metricLabel}</span>
              </div>
            </div>
            <h3 class="work-title">{work.title}</h3>
            <p class="work-description">{work.description}</p>
            <div class="work-tags">
              {work.tags.map((tag) => (
                <span class="work-tag">{tag}</span>
              ))}
            </div>
          </article>
        ))}
      </div>

      <div class="section-cta">
        <a href={`${base}/projects`} class="btn-outline">View all projects</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       CONTACT — Clean CTA
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="contact-teaser" aria-label="Get in touch">
    <div class="container content">
      <div class="section-header centered" data-animate="reveal">
        <span class="section-label">Get in Touch</span>
        <h2>Let's connect</h2>
      </div>
      <p class="contact-text" data-animate="reveal">
        Whether you're interested in AI research, fintech, or just want to say hello — I'd love to hear from you.
      </p>
      <div class="contact-actions" data-animate="reveal">
        <a href="mailto:wingchunleung8@gmail.com" class="btn-primary">Say hello</a>
        <a href={`${base}/contact`} class="btn-outline">All contact info</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ══════════════════════════════════════════════════════════════════════
     HERO — Full viewport, bright, welcoming
     ══════════════════════════════════════════════════════════════════════ */

  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: var(--color-bg);
    overflow: hidden;
    padding: 0 var(--gutter);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 720px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  /* ── Phase 1: Waving hand entrance (0-2s) ────────────────────────── */
  .hero-wave {
    opacity: 0;
    transform: scale(0.3) rotate(-20deg);
    animation: handEntrance 0.9s cubic-bezier(0.34, 1.56, 0.64, 1) 0.5s forwards;
  }

  .wave-hand {
    display: inline-block;
    font-size: clamp(3.5rem, 7vw, 5rem);
    transform-origin: 70% 70%;
    animation: waveMotion 2.5s ease-in-out 1.4s 2;
  }

  @keyframes handEntrance {
    0% { opacity: 0; transform: scale(0.3) rotate(-20deg); }
    60% { opacity: 1; transform: scale(1.1) rotate(5deg); }
    100% { opacity: 1; transform: scale(1) rotate(0deg); }
  }

  @keyframes waveMotion {
    0% { transform: rotate(0deg); }
    10% { transform: rotate(14deg); }
    20% { transform: rotate(-8deg); }
    30% { transform: rotate(14deg); }
    40% { transform: rotate(-4deg); }
    50% { transform: rotate(10deg); }
    60% { transform: rotate(0deg); }
    100% { transform: rotate(0deg); }
  }

  /* ── Phase 2: Text mask reveal (1.5-3s) ──────────────────────────── */
  .hero-greeting {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 6.5vw, 5rem);
    font-weight: var(--weight-light);
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text);
    overflow: hidden;
  }

  .greeting-mask {
    display: block;
    overflow: hidden;
  }

  .greeting-text {
    display: block;
    transform: translateY(110%);
    animation: textReveal 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .greeting-1 { animation-delay: 1.6s; }

  @keyframes textReveal {
    to { transform: translateY(0); }
  }

  /* ── Phase 3: CTA fade in (3s+) ─────────────────────────────────── */
  .hero-cta-wrap {
    opacity: 0;
    transform: translateY(16px);
    animation: ctaReveal 0.8s var(--ease-out) 2.8s forwards;
  }

  @keyframes ctaReveal {
    to { opacity: 1; transform: translateY(0); }
  }

  .btn-hero {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: var(--weight-medium);
    padding: 14px 36px;
    background: var(--color-ink);
    color: var(--color-bg);
    border-radius: 100px;
    text-decoration: none;
    transition: all var(--duration-normal) var(--ease-out);
    min-height: 48px;
    letter-spacing: 0.02em;
  }

  .btn-hero svg {
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .btn-hero:hover {
    background: var(--color-vermillion);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(199, 62, 29, 0.2);
  }

  .btn-hero:hover svg {
    transform: translateY(3px);
  }

  .btn-hero::after { display: none; }

  @media (prefers-color-scheme: dark) {
    .btn-hero {
      background: rgba(245, 245, 247, 0.95);
      color: #1d1d1f;
    }
    .btn-hero:hover {
      background: var(--color-vermillion);
      color: #fff;
    }
  }

  /* ── Scroll indicator (Apple-style) ─────────────────────────────── */
  .scroll-cue {
    position: absolute;
    bottom: var(--space-5);
    left: 50%;
    transform: translateX(-50%);
    opacity: 0;
    animation: ctaReveal 0.6s var(--ease-out) 3.2s forwards;
    z-index: 2;
  }

  .scroll-line-track {
    width: 1px;
    height: 60px;
    background: var(--color-border);
    border-radius: 1px;
    overflow: hidden;
  }

  .scroll-line-fill {
    width: 100%;
    height: 30px;
    background: var(--color-vermillion);
    border-radius: 1px;
    animation: scrollLine 2s var(--ease-in-out) infinite 3.5s;
  }

  @keyframes scrollLine {
    0% { transform: translateY(-30px); }
    50% { transform: translateY(60px); }
    100% { transform: translateY(60px); }
  }

  /* ══════════════════════════════════════════════════════════════════════
     INTRODUCTION — Name reveal after scroll
     ══════════════════════════════════════════════════════════════════════ */

  .intro {
    padding: var(--section-gap) 0;
    background: var(--color-bg);
  }

  .intro-content {
    text-align: center;
    opacity: 0;
    transform: translateY(40px);
  }

  .intro-content.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 1s var(--ease-out),
                transform 1s var(--ease-out);
  }

  .intro-greeting {
    font-family: var(--font-mono);
    font-size: var(--text-small);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-wash);
    margin-bottom: var(--space-2);
  }

  .intro-name {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: var(--weight-light);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-5);
  }

  .intro-divider {
    width: 48px;
    height: 2px;
    background: var(--color-vermillion);
    margin: 0 auto var(--space-5);
    border-radius: 1px;
  }

  .intro-tagline {
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    line-height: 1.5;
    color: var(--color-wash);
    max-width: 520px;
    margin: 0 auto var(--space-4);
  }

  .intro-tagline strong {
    color: var(--color-text);
    font-weight: var(--weight-medium);
  }

  .intro-bio {
    font-size: var(--text-body);
    color: var(--color-wash);
    max-width: 560px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  /* ══════════════════════════════════════════════════════════════════════
     LOGO STRIP — Visual experience credibility
     ══════════════════════════════════════════════════════════════════════ */

  .logo-strip {
    padding: var(--space-8) 0;
    background: var(--color-bg);
    opacity: 0;
    transform: translateY(30px);
  }

  .logo-strip.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 1s var(--ease-out),
                transform 1s var(--ease-out);
  }

  .logo-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
    flex-wrap: wrap;
  }

  .logo-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .logo-text-mark {
    font-family: var(--font-body);
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.04em;
    color: var(--brand, var(--color-text));
    opacity: 0.7;
    transition: opacity var(--duration-normal) var(--ease-out);
  }

  .logo-item:hover .logo-text-mark {
    opacity: 1;
  }

  .logo-role {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-wash);
  }

  /* ══════════════════════════════════════════════════════════════════════
     SECTION HEADERS — Reusable pattern
     ══════════════════════════════════════════════════════════════════════ */

  .section-header {
    margin-bottom: var(--space-8);
    opacity: 0;
    transform: translateY(30px);
  }

  .section-header.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.8s var(--ease-out),
                transform 0.8s var(--ease-out);
  }

  .section-header.centered {
    text-align: center;
  }

  .section-header h2 {
    margin-top: var(--space-2);
  }

  /* ══════════════════════════════════════════════════════════════════════
     JOURNEY — Timeline
     ══════════════════════════════════════════════════════════════════════ */

  .journey {
    padding: var(--section-gap) 0;
    background: var(--color-stone);
  }

  .journey-timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .journey-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    opacity: 0;
    transform: translateY(40px);
  }

  .journey-step.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                transform var(--duration-reveal) var(--ease-out) var(--delay, 0s);
  }

  .step-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding-top: var(--space-1);
  }

  .step-number {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--step-accent, var(--color-vermillion));
    font-weight: var(--weight-medium);
  }

  .step-line {
    width: 2px;
    flex: 1;
    min-height: 40px;
    background: linear-gradient(to bottom, var(--step-accent, var(--color-border)), var(--color-border));
    border-radius: 1px;
  }

  .step-content {
    max-width: var(--max-content);
  }

  .step-meta {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .step-place {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-text);
    font-weight: var(--weight-medium);
  }

  .step-period {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-wide);
    color: var(--color-wash);
  }

  .step-heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: var(--weight-light);
    margin-bottom: var(--space-2);
  }

  .step-text {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  /* ══════════════════════════════════════════════════════════════════════
     FEATURED WORK — Cards with impact metrics
     ══════════════════════════════════════════════════════════════════════ */

  .featured-work {
    padding: var(--section-gap) 0;
    background: var(--color-bg);
  }

  .work-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  @media (min-width: 768px) {
    .work-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .work-card {
    background: var(--color-stone);
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    transition: transform var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
    opacity: 0;
    transform: translateY(40px);
  }

  .work-card.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                transform var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .work-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .work-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-3);
  }

  .work-org-badge {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.02em;
    color: var(--org-color, var(--color-text));
    padding: 6px 14px;
