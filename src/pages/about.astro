---
/**
 * About Page — Visual, premium, Apple/SaaS-quality
 * HCI: Recognition > Recall — logos, colors, visual cards instead of text walls
 * HCI: Visceral — immediate visual impression of professional credibility
 * HCI: Gestalt Proximity — grouped cards, clear visual sections
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const experience = [
  {
    org: 'HKUST',
    role: 'Research Assistant – AI in Asset Management (Business School)',
    period: '2026 — Present',
    color: '#003366',
    highlight: 'LLM-driven macro analysis, asset allocation, and investment decision support',
    metrics: ['~RMB 5T AUM context', 'Macro strategy', 'Multi-agent systems'],
  },
  {
    org: 'Carta',
    role: 'Private Equity / Equity Advisory Analyst',
    period: '2024 — 2025',
    color: '#1a1a1a',
    highlight: 'Equity & stock option advisory — tender offers, liquidity scenarios',
    metrics: ['~4.8/5 satisfaction', '~70% faster modeling', 'VC/PE-backed clients'],
  },
  {
    org: 'Costco',
    role: 'Financial Systems Analyst',
    period: '2023 — 2024',
    color: '#e31837',
    highlight: 'Automated financial reporting, audit support, and expense forecasting',
    metrics: ['~80 hrs/month saved', '~99% automation', 'Financial planning'],
  },
  {
    org: 'Camelotta Advisors',
    role: 'Investment Analyst Intern',
    period: '2022',
    color: '#2d5a3d',
    highlight: 'Investment research and analysis for HNW client portfolios',
    metrics: ['Wealth management', '$180M+ AUM', 'Options & hedging'],
  },
  {
    org: 'Costco',
    role: 'Revenue Accounting Intern',
    period: '2022',
    color: '#e31837',
    highlight: 'Automated reconciliation and journal entry workflows',
    metrics: ['~40 hrs/month saved', 'Revenue accounting', 'Process improvement'],
  },
];

const education = [
  {
    org: 'HKUST',
    degree: 'MSc Artificial Intelligence',
    period: 'Expected graduation 2027',
    color: '#003366',
    detail: '2× Scholarship Recipient · RA in AI & Asset Management (Business School)',
  },
  {
    org: 'University of Washington',
    degree: 'BBA Finance & Information Systems',
    period: 'Graduated 2022',
    color: '#4b2e83',
    detail: 'Dean\'s List · Double Major · CFO of UW Blockchain Society · Track President, International Business Program',
  },
];

// Stats removed — info now shown in places section + homepage highlights
---

<BaseLayout title="About — Wing Chun Leung" description="Learn about Wing Chun Leung — bridging finance and AI, from Hong Kong to HKUST.">
  <Header slot="header" />

  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <span class="section-label">About</span>
      <h1>Finance, markets,<br />and technology</h1>
      <p class="hero-sub">
        From Hong Kong through the US and back — combining investment
        expertise with technology to work smarter and think deeper.
      </p>
    </div>
  </section>

  <!-- Background — places lived & languages -->
  <section class="places-section" aria-label="Background">
    <div class="container">
      <div class="places-row" data-animate="reveal">
        <div class="places-group">
          <span class="places-label">Locations</span>
          <div class="places-items">
            <div class="place-card place-card--photo">
              <img src={`${base}/logos/hk.webp`} alt="Hong Kong" class="place-photo" loading="lazy" />
              <span class="place-name">Hong Kong, China</span>
            </div>
            <div class="place-card place-card--photo">
              <img src={`${base}/logos/seattle.png`} alt="Seattle" class="place-photo" loading="lazy" />
              <span class="place-name">Washington, USA</span>
              <span class="place-detail">7 years</span>
            </div>
            <div class="place-card place-card--photo">
              <img src={`${base}/logos/north-carolina.jpg`} alt="North Carolina" class="place-photo" loading="lazy" />
              <span class="place-name">North Carolina, USA</span>
              <span class="place-detail">1 year</span>
            </div>
          </div>
        </div>
        <div class="places-divider" aria-hidden="true"></div>
        <div class="places-group">
          <span class="places-label">Languages</span>
          <div class="places-items">
            <div class="place-card">
              <span class="place-emoji" aria-hidden="true">&#127482;&#127480;</span>
              <span class="place-name">English</span>
              <span class="place-detail">Fluent</span>
            </div>
            <div class="place-card">
              <span class="place-emoji" aria-hidden="true">&#127469;&#127472;</span>
              <span class="place-name">Cantonese</span>
              <span class="place-detail">Native</span>
            </div>
            <div class="place-card">
              <span class="place-emoji" aria-hidden="true">&#127464;&#127475;</span>
              <span class="place-name">Mandarin</span>
              <span class="place-detail">Native</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Experience -->
  <section class="exp-section" aria-label="Experience">
    <div class="container">
      <div class="section-header" data-animate="reveal">
        <span class="section-label">Experience</span>
        <h2>Professional Experience</h2>
      </div>

      <div class="exp-grid">
        {experience.map((exp, i) => (
          <article class="exp-card" data-animate="reveal" style={`--delay: ${i * 0.1}s; --brand: ${exp.color}`}>
            <div class="exp-card-top">
              <span class="exp-org">{exp.org}</span>
              <span class="exp-period">{exp.period}</span>
            </div>
            <h3 class="exp-role">{exp.role}</h3>
            <p class="exp-highlight">{exp.highlight}</p>
            <div class="exp-metrics">
              {exp.metrics.map((m) => (
                <span class="exp-metric">{m}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Education -->
  <section class="edu-section" aria-label="Education">
    <div class="container">
      <div class="section-header" data-animate="reveal">
        <span class="section-label">Education</span>
        <h2>Education</h2>
      </div>

      <div class="edu-grid">
        {education.map((edu, i) => (
          <article class="edu-card" data-animate="reveal" style={`--delay: ${i * 0.1}s; --brand: ${edu.color}`}>
            <span class="edu-org">{edu.org}</span>
            <h3 class="edu-degree">{edu.degree}</h3>
            <span class="edu-period">{edu.period}</span>
            <p class="edu-detail">{edu.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Bio -->
  <section class="bio-section" aria-label="Personal">
    <div class="container content">
      <div class="section-header centered" data-animate="reveal">
        <span class="section-label">The Human</span>
        <h2>Beyond the resume</h2>
      </div>
      <div class="bio-content" data-animate="reveal">
        <p>
          Born and raised in <strong>Hong Kong</strong>, educated in the <strong>United States</strong>,
          now back home working at the intersection of finance and technology. I speak English, Cantonese, and Mandarin.
        </p>
        <p>
          I've been a guest speaker five times — at universities, high schools, and community organizations.
          I've mentored interns, tutored students, and led multiple student organizations.
          I believe the most important skill is the ability to make others better.
        </p>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────────────────────────────── */
  .page-hero {
    padding-top: calc(72px + var(--section-gap));
    padding-bottom: var(--space-6);
    position: relative;
    overflow: hidden;
  }

  .page-hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 60%;
    height: 150%;
    background: radial-gradient(circle, rgba(199, 62, 29, 0.04) 0%, transparent 60%);
    pointer-events: none;
  }

  .page-hero .section-label {
    opacity: 0; transform: translateY(20px);
    animation: pageReveal 0.8s var(--ease-out) 0.2s forwards;
  }

  .page-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    margin-top: var(--space-3);
    margin-bottom: var(--space-3);
    opacity: 0; transform: translateY(30px);
    animation: pageReveal 0.8s var(--ease-out) 0.4s forwards;
    background: linear-gradient(135deg, var(--color-ink) 0%, var(--color-vermillion) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: clamp(1rem, 1.8vw, 1.2rem);
    color: var(--color-wash);
    max-width: 520px;
    opacity: 0; transform: translateY(20px);
    animation: pageReveal 0.8s var(--ease-out) 0.6s forwards;
  }

  @keyframes pageReveal { to { opacity: 1; transform: translateY(0); } }

  /* ── Places & Languages ──────────────────────────────────────────── */
  .places-section {
    padding: var(--space-6) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .places-row {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: var(--space-6);
    flex-wrap: wrap;
    opacity: 0; transform: translateY(20px);
  }

  .places-row.visible {
    opacity: 1; transform: translateY(0);
    transition: opacity 0.8s var(--ease-out), transform 0.8s var(--ease-out);
  }

  .places-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .places-label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-vermillion);
    font-weight: var(--weight-medium);
  }

  .places-items {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: center;
  }

  .places-divider {
    width: 1px;
    height: 60px;
    background: var(--color-border);
    align-self: center;
  }

  @media (max-width: 640px) {
    .places-divider { display: none; }
    .places-row { gap: var(--space-5); }
  }

  .place-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 4px;
  }

  .place-card--photo {
    width: 140px;
  }

  .place-photo {
    width: 120px;
    height: 80px;
    object-fit: cover;
    border-radius: var(--radius-md);
    margin-bottom: 4px;
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .place-card:hover .place-photo {
    transform: scale(1.05);
  }

  .place-emoji {
    font-size: 1.5rem;
    line-height: 1;
    margin-bottom: 4px;
  }

  .place-name {
    font-weight: var(--weight-medium);
    font-size: var(--text-small);
  }

  .place-detail {
    font-size: var(--text-caption);
    color: var(--color-wash);
  }

  /* ── Section headers ───────────────────────────────────────────────── */
  .section-header {
    margin-bottom: var(--space-6);
    opacity: 0; transform: translateY(30px);
  }

  .section-header.visible {
    opacity: 1; transform: translateY(0);
    transition: opacity 0.8s var(--ease-out), transform 0.8s var(--ease-out);
  }

  .section-header.centered { text-align: center; }
  .section-header h2 { margin-top: var(--space-2); }

  /* ── Experience cards ──────────────────────────────────────────────── */
  .exp-section {
    padding: var(--section-gap) 0;
  }

  .exp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    max-width: 1000px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .exp-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .exp-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .exp-card {
    position: relative;
    overflow: hidden;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    border-top: 3px solid var(--brand, var(--color-border));
    opacity: 0; transform: translateY(30px);
    transition: transform var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .exp-card.visible {
    opacity: 1; transform: translateY(0);
    transition: opacity var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                transform var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .exp-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08);
  }

  /* Spotlight glow on exp cards */
  .exp-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      400px circle at var(--mx, 50%) var(--my, 50%),
      rgba(199, 62, 29, 0.06),
      transparent 40%
    );
    opacity: 0;
    transition: opacity var(--duration-normal) var(--ease-out);
    pointer-events: none;
  }

  .exp-card:hover::before { opacity: 1; }

  .exp-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-3);
  }

  .exp-org {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: var(--weight-semibold);
    color: var(--brand, var(--color-text));
    letter-spacing: 0.02em;
  }

  .exp-period {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-wash);
  }

  .exp-role {
    font-size: var(--text-body);
    font-weight: var(--weight-medium);
    margin-bottom: var(--space-2);
    line-height: var(--leading-snug);
  }

  .exp-highlight {
    font-size: var(--text-small);
    color: var(--color-wash);
    margin-bottom: var(--space-3);
  }

  .exp-metrics {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .exp-metric {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: var(--tracking-wide);
    color: var(--color-wash);
    padding: 4px 10px;
    border: 1px solid var(--color-border);
    border-radius: 100px;
  }

  /* ── Education cards ───────────────────────────────────────────────── */
  .edu-section {
    padding: var(--section-gap) 0;
    background: var(--color-surface);
  }

  .edu-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 768px) {
    .edu-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .edu-card {
    background: var(--color-bg);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    border-left: 3px solid var(--brand, var(--color-border));
    opacity: 0; transform: translateY(30px);
    transition: transform var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .edu-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .edu-card.visible {
    opacity: 1; transform: translateY(0);
    transition: opacity var(--duration-reveal) var(--ease-out) var(--delay, 0s),
                transform var(--duration-reveal) var(--ease-out) var(--delay, 0s);
  }

  .edu-org {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    font-weight: var(--weight-semibold);
    color: var(--brand, var(--color-text));
    letter-spacing: 0.04em;
    text-transform: uppercase;
    display: block;
    margin-bottom: var(--space-2);
  }

  .edu-degree {
    font-size: var(--text-h3);
    margin-bottom: var(--space-1);
  }

  .edu-period {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-wash);
    display: block;
    margin-bottom: var(--space-2);
  }

  .edu-detail {
    font-size: var(--text-small);
    color: var(--color-wash);
  }

  /* ── Bio section ───────────────────────────────────────────────────── */
  .bio-section {
    padding: var(--section-gap) 0;
  }

  .bio-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
    opacity: 0; transform: translateY(30px);
  }

  .bio-content.visible {
    opacity: 1; transform: translateY(0);
    transition: opacity 0.8s var(--ease-out) 0.1s, transform 0.8s var(--ease-out) 0.1s;
  }

  .bio-content p {
    color: var(--color-wash);
    margin-bottom: var(--space-3);
    line-height: var(--leading-relaxed);
  }

  .bio-content strong {
    color: var(--color-text);
    font-weight: var(--weight-medium);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // GSAP scroll reveals for all sections
  gsap.utils.toArray('[data-animate="reveal"]').forEach((el) => {
    const element = el as HTMLElement;
    const delay = parseFloat(element.style.getPropertyValue('--delay') || '0');
    gsap.fromTo(element,
      { opacity: 0, y: 40 },
      {
        opacity: 1, y: 0, duration: 0.8, delay, ease: 'power3.out',
        scrollTrigger: { trigger: element, start: 'top 85%', toggleActions: 'play none none none' },
      }
    );
  });

  // Animated stat counter
  document.querySelectorAll('.stat-value[data-count]').forEach((el) => {
    const target = el as HTMLElement;
    const raw = target.dataset.count || '0';
    const hasDecimal = raw.includes('.');
    const hasSuffix = raw.match(/[×+]/);
    const numericPart = parseFloat(raw.replace(/[^0-9.]/g, ''));
    const suffix = raw.replace(/[0-9.]/g, '');

    ScrollTrigger.create({
      trigger: target,
      start: 'top 80%',
      once: true,
      onEnter: () => {
        const obj = { val: 0 };
        gsap.to(obj, {
          val: numericPart,
          duration: 1.5,
          ease: 'power2.out',
          onUpdate: () => {
            const display = hasDecimal ? obj.val.toFixed(1) : Math.round(obj.val).toString();
            target.textContent = display + suffix;
          },
        });
      },
    });
  });

  // Spotlight glow on exp cards
  document.querySelectorAll('.exp-card').forEach((card) => {
    card.addEventListener('pointermove', (e: PointerEvent) => {
      const rect = (card as HTMLElement).getBoundingClientRect();
      (card as HTMLElement).style.setProperty('--mx', `${e.clientX - rect.left}px`);
      (card as HTMLElement).style.setProperty('--my', `${e.clientY - rect.top}px`);
    });
  });
</script>
