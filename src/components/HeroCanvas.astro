---
/**
 * HeroCanvas — Premium immersive hero with flowing particle network
 *
 * Creates a "data flowing through a neural network" effect:
 * - Particles move along smooth curves
 * - Connected by glowing lines when close
 * - Subtle mouse interaction (particles attracted toward cursor)
 * - Soft gradient color palette (peach → blue → purple)
 * - Responsive: full effect on desktop, simplified on mobile
 *
 * HCI: Visceral level — immediate emotional engagement
 * HCI: H3 (Minimalism) — animation supports, doesn't compete with text
 * Performance: Custom canvas (~4KB), 60fps, GPU-friendly
 */
---

<div class="hero-canvas-container">
  <!-- Layer 1: Animated CSS gradient (0 JS, rich color depth) -->
  <div class="hero-gradient-bg" aria-hidden="true"></div>

  <!-- Layer 2: Flowing SVG circuit lines -->
  <svg class="hero-svg-lines" viewBox="0 0 1400 800" fill="none" preserveAspectRatio="none" aria-hidden="true">
    <path class="flow-line fl-1" d="M-50,400 C200,340 500,460 750,400 S1100,340 1450,400" />
    <path class="flow-line fl-2" d="M-50,280 C300,230 550,330 800,270 S1100,300 1450,280" />
    <path class="flow-line fl-3" d="M-50,550 C250,520 480,580 720,540 S1050,560 1450,550" />
    <path class="flow-line fl-4" d="M-50,180 C350,150 600,210 850,170 S1150,200 1450,180" />
    <path class="flow-line fl-5" d="M-50,650 C200,630 450,670 700,640 S1000,660 1450,650" />
  </svg>

  <!-- Layer 3: Canvas particle network -->
  <canvas id="hero-canvas" aria-hidden="true"></canvas>

  <!-- Layer 4: Radial overlay for text readability -->
  <div class="hero-gradient-overlay" aria-hidden="true"></div>
</div>

<style>
  .hero-canvas-container {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  /* Layer 1: Animated gradient — rich color depth behind particles */
  .hero-gradient-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(-45deg,
      rgba(199, 62, 29, 0.06),
      rgba(125, 158, 140, 0.08),
      rgba(100, 140, 200, 0.06),
      rgba(160, 120, 170, 0.06)
    );
    background-size: 400% 400%;
    animation: gradientShift 20s ease infinite;
  }

  @keyframes gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* Layer 2: SVG flowing circuit lines */
  .hero-svg-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .flow-line {
    stroke-width: 1;
    stroke-dasharray: 12 60;
    stroke-dashoffset: 0;
    animation: flowLine 10s linear infinite;
  }

  .fl-1 { stroke: rgba(199, 62, 29, 0.08); animation-duration: 8s; }
  .fl-2 { stroke: rgba(125, 158, 140, 0.08); animation-duration: 12s; animation-delay: -3s; }
  .fl-3 { stroke: rgba(100, 140, 200, 0.07); animation-duration: 10s; animation-delay: -5s; }
  .fl-4 { stroke: rgba(180, 140, 100, 0.06); animation-duration: 14s; animation-delay: -7s; }
  .fl-5 { stroke: rgba(160, 120, 170, 0.06); animation-duration: 11s; animation-delay: -2s; }

  @keyframes flowLine {
    to { stroke-dashoffset: -144; }
  }

  /* Layer 3: Canvas */
  #hero-canvas {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    display: block;
  }

  .hero-gradient-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse at 50% 50%,
        transparent 20%,
        rgba(255, 255, 255, 0.3) 50%,
        rgba(255, 255, 255, 0.7) 80%,
        rgba(255, 255, 255, 0.92) 100%
      ),
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.1) 0%,
        rgba(255, 255, 255, 0) 40%,
        rgba(255, 255, 255, 0) 60%,
        rgba(255, 255, 255, 0.3) 100%
      );
    pointer-events: none;
  }

  /* dark mode removed — light only */

  @media (prefers-reduced-motion: reduce) {
    #hero-canvas {
      display: none;
    }
  }
</style>

<script>
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  if (!canvas) throw new Error('Canvas not found');
  const ctx = canvas.getContext('2d');
  if (!ctx) throw new Error('2D context not available');

  // ── Configuration ──────────────────────────────────────────────────
  const CONFIG = {
    particleCount: 90,
    connectionDistance: 160,
    particleSpeed: 0.35,
    mouseRadius: 220,
    mouseForce: 0.025,
    colors: [
      { r: 199, g: 62, b: 29 },    // vermillion
      { r: 100, g: 158, b: 130 },   // celadon (slightly more saturated)
      { r: 200, g: 150, b: 80 },    // warm amber
      { r: 80, g: 130, b: 200 },    // rich blue
      { r: 160, g: 100, b: 180 },   // vivid purple
      { r: 230, g: 100, b: 70 },    // bright coral
      { r: 180, g: 80, b: 120 },    // rose
    ],
    lineOpacityBase: 0.18,
    particleOpacityBase: 0.65,
    glowSize: 5,
    // Data pulse config — bright dots traveling along connections
    pulseCount: 12,
    pulseSpeed: 1.5,
    pulseSize: 2,
    pulseGlow: 8,
  };

  // Reduce particles on mobile
  const isMobile = window.innerWidth < 768;
  if (isMobile) {
    CONFIG.particleCount = 45;
    CONFIG.connectionDistance = 110;
    CONFIG.glowSize = 2.5;
    CONFIG.pulseCount = 6;
  }

  // ── State ──────────────────────────────────────────────────────────
  let width = 0;
  let height = 0;
  let dpr = 1;
  let mouseX = -1000;
  let mouseY = -1000;
  let animationId: number;
  let particles: Particle[] = [];
  let dataPulses: DataPulse[] = [];
  let frameCount = 0;

  interface Particle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    color: { r: number; g: number; b: number };
    size: number;
    opacity: number;
    pulsePhase: number;
    pulseSpeed: number;
  }

  interface DataPulse {
    fromIdx: number;  // particle index
    toIdx: number;    // particle index
    progress: number; // 0 → 1
    speed: number;
    color: { r: number; g: number; b: number };
    active: boolean;
  }

  // ── Resize ─────────────────────────────────────────────────────────
  function resize() {
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    const rect = canvas.getBoundingClientRect();
    width = rect.width;
    height = rect.height;
    canvas.width = width * dpr;
    canvas.height = height * dpr;
    ctx!.scale(dpr, dpr);
  }

  // ── Create particles ───────────────────────────────────────────────
  function createParticles() {
    particles = [];
    for (let i = 0; i < CONFIG.particleCount; i++) {
      const angle = Math.random() * Math.PI * 2;
      const speed = CONFIG.particleSpeed * (0.5 + Math.random() * 0.5);
      particles.push({
        x: Math.random() * width,
        y: Math.random() * height,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        color: CONFIG.colors[Math.floor(Math.random() * CONFIG.colors.length)],
        size: 1.5 + Math.random() * 2,
        opacity: CONFIG.particleOpacityBase + Math.random() * 0.3,
        pulsePhase: Math.random() * Math.PI * 2,
        pulseSpeed: 0.01 + Math.random() * 0.02,
      });
    }
  }

  // ── Update ─────────────────────────────────────────────────────────
  function update() {
    for (const p of particles) {
      // Move
      p.x += p.vx;
      p.y += p.vy;

      // Wrap around edges (seamless)
      if (p.x < -10) p.x = width + 10;
      if (p.x > width + 10) p.x = -10;
      if (p.y < -10) p.y = height + 10;
      if (p.y > height + 10) p.y = -10;

      // Mouse interaction — gentle attraction
      const dx = mouseX - p.x;
      const dy = mouseY - p.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < CONFIG.mouseRadius && dist > 0) {
        const force = (1 - dist / CONFIG.mouseRadius) * CONFIG.mouseForce;
        p.vx += (dx / dist) * force;
        p.vy += (dy / dist) * force;
      }

      // Damping (prevents acceleration buildup)
      p.vx *= 0.998;
      p.vy *= 0.998;

      // Ensure minimum speed
      const speed = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
      if (speed < CONFIG.particleSpeed * 0.3) {
        const angle = Math.atan2(p.vy, p.vx);
        p.vx = Math.cos(angle) * CONFIG.particleSpeed * 0.3;
        p.vy = Math.sin(angle) * CONFIG.particleSpeed * 0.3;
      }

      // Pulse
      p.pulsePhase += p.pulseSpeed;
    }

    // Update data pulses
    for (const pulse of dataPulses) {
      if (!pulse.active) continue;
      pulse.progress += pulse.speed / 60; // normalize to ~1s travel time
      if (pulse.progress >= 1) pulse.active = false;
    }
    dataPulses = dataPulses.filter(p => p.active);

    // Spawn new data pulses periodically
    frameCount++;
    if (frameCount % 8 === 0 && dataPulses.length < CONFIG.pulseCount) {
      // Find a random connected pair
      for (let attempt = 0; attempt < 5; attempt++) {
        const i = Math.floor(Math.random() * particles.length);
        const j = Math.floor(Math.random() * particles.length);
        if (i === j) continue;
        const dx = particles[i].x - particles[j].x;
        const dy = particles[i].y - particles[j].y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < CONFIG.connectionDistance) {
          dataPulses.push({
            fromIdx: i,
            toIdx: j,
            progress: 0,
            speed: CONFIG.pulseSpeed * (0.7 + Math.random() * 0.6),
            color: CONFIG.colors[Math.floor(Math.random() * CONFIG.colors.length)],
            active: true,
          });
          break;
        }
      }
    }
  }

  // ── Pre-render glow sprites (PERF: avoid createRadialGradient per frame) ──
  const glowSprites = new Map<string, HTMLCanvasElement>();
  function getGlowSprite(r: number, g: number, b: number): HTMLCanvasElement {
    const key = `${r},${g},${b}`;
    if (glowSprites.has(key)) return glowSprites.get(key)!;
    const size = 64;
    const c = document.createElement('canvas');
    c.width = size; c.height = size;
    const gc = c.getContext('2d')!;
    const grad = gc.createRadialGradient(size/2, size/2, 0, size/2, size/2, size/2);
    grad.addColorStop(0, `rgba(${r}, ${g}, ${b}, 0.6)`);
    grad.addColorStop(0.4, `rgba(${r}, ${g}, ${b}, 0.15)`);
    grad.addColorStop(1, `rgba(${r}, ${g}, ${b}, 0)`);
    gc.fillStyle = grad;
    gc.fillRect(0, 0, size, size);
    glowSprites.set(key, c);
    return c;
  }

  // White glow for data pulse cores
  const pulseGlowSprite = (() => {
    const size = 32;
    const c = document.createElement('canvas');
    c.width = size; c.height = size;
    const gc = c.getContext('2d')!;
    const grad = gc.createRadialGradient(size/2, size/2, 0, size/2, size/2, size/2);
    grad.addColorStop(0, 'rgba(255, 255, 255, 0.9)');
    grad.addColorStop(0.3, 'rgba(255, 255, 255, 0.3)');
    grad.addColorStop(1, 'rgba(255, 255, 255, 0)');
    gc.fillStyle = grad;
    gc.fillRect(0, 0, size, size);
    return c;
  })();

  // ── Draw (optimized) ───────────────────────────────────────────────
  function draw() {
    const c = ctx!;
    c.clearRect(0, 0, width, height);

    // Draw connections — batched by opacity level, curved lines
    c.lineWidth = 0.7;
    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const a = particles[i];
        const b = particles[j];
        const dx = a.x - b.x;
        const dy = a.y - b.y;
        const distSq = dx * dx + dy * dy;
        const maxDistSq = CONFIG.connectionDistance * CONFIG.connectionDistance;

        if (distSq < maxDistSq) {
          const dist = Math.sqrt(distSq);
          const opacity = (1 - dist / CONFIG.connectionDistance) * CONFIG.lineOpacityBase;
          const r = (a.color.r + b.color.r) >> 1;
          const g = (a.color.g + b.color.g) >> 1;
          const bl = (a.color.b + b.color.b) >> 1;

          // Subtle curve for organic fiber-optic feel
          const midX = (a.x + b.x) / 2;
          const midY = (a.y + b.y) / 2 + (a.x - b.x) * 0.08;

          c.beginPath();
          c.moveTo(a.x | 0, a.y | 0);
          c.quadraticCurveTo(midX | 0, midY | 0, b.x | 0, b.y | 0);
          c.strokeStyle = `rgba(${r},${g},${bl},${opacity})`;
          c.stroke();
        }
      }
    }

    // Draw data pulses — pre-rendered glow sprites
    for (const pulse of dataPulses) {
      if (!pulse.active) continue;
      const a = particles[pulse.fromIdx];
      const b = particles[pulse.toIdx];
      if (!a || !b) continue;

      const t = pulse.progress;
      // Follow the same curve as the connection
      const midX = (a.x + b.x) / 2;
      const midY = (a.y + b.y) / 2 + (a.x - b.x) * 0.08;
      // Quadratic bezier at t
      const u = 1 - t;
      const px = u * u * a.x + 2 * u * t * midX + t * t * b.x;
      const py = u * u * a.y + 2 * u * t * midY + t * t * b.y;

      // Color glow
      const sprite = getGlowSprite(pulse.color.r, pulse.color.g, pulse.color.b);
      const gs = CONFIG.pulseGlow * 2;
      c.globalAlpha = 0.8;
      c.drawImage(sprite, px - gs, py - gs, gs * 2, gs * 2);
      c.globalAlpha = 1;

      // White core
      c.drawImage(pulseGlowSprite, px - CONFIG.pulseSize * 3, py - CONFIG.pulseSize * 3, CONFIG.pulseSize * 6, CONFIG.pulseSize * 6);
    }

    // Draw particles with pre-rendered glow
    for (const p of particles) {
      const pulse = 0.7 + 0.3 * Math.sin(p.pulsePhase);
      const size = p.size * pulse;
      const opacity = p.opacity * pulse;

      // Glow sprite
      const sprite = getGlowSprite(p.color.r, p.color.g, p.color.b);
      const gs = size * CONFIG.glowSize;
      c.globalAlpha = opacity;
      c.drawImage(sprite, p.x - gs, p.y - gs, gs * 2, gs * 2);
      c.globalAlpha = 1;

      // Core dot
      c.beginPath();
      c.arc(p.x | 0, p.y | 0, size * 0.5, 0, Math.PI * 2);
      c.fillStyle = `rgba(${p.color.r},${p.color.g},${p.color.b},${opacity})`;
      c.fill();
    }
  }

  // ── Animation loop ─────────────────────────────────────────────────
  function animate() {
    update();
    draw();
    animationId = requestAnimationFrame(animate);
  }

  // ── Initialize ─────────────────────────────────────────────────────
  function init() {
    resize();
    createParticles();
    animate();
  }

  // ── Event listeners ────────────────────────────────────────────────
  window.addEventListener('resize', () => {
    resize();
    // Recreate particles for new dimensions
    createParticles();
  });

  // Track mouse (desktop only)
  if (!isMobile) {
    canvas.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      mouseX = e.clientX - rect.left;
      mouseY = e.clientY - rect.top;
    });

    canvas.addEventListener('mouseleave', () => {
      mouseX = -1000;
      mouseY = -1000;
    });
  }

  // Pause when not visible (performance)
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      cancelAnimationFrame(animationId);
    } else {
      animate();
    }
  });

  // Respect reduced motion
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  if (!prefersReducedMotion.matches) {
    init();
  }

  prefersReducedMotion.addEventListener('change', (e) => {
    if (e.matches) {
      cancelAnimationFrame(animationId);
      ctx!.clearRect(0, 0, width, height);
    } else {
      init();
    }
  });
</script>
