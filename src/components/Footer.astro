---
/**
 * Footer
 * HCI: H1 (Consistency) — same footer on every page
 * Minimal, warm, with vermillion seal mark
 */
const year = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <!-- Pre-footer CTA -->
  <div class="footer-cta">
    <div class="container">
      <p class="footer-cta-label">Ready to connect?</p>
      <h2 class="footer-cta-heading">Let's build something<br/>together.</h2>
      <a href="mailto:wingchunleung8@gmail.com" class="footer-cta-btn">
        <span>Get in touch</span>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M4 10h12M12 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Utility footer -->
  <div class="container footer-content">
    <div class="footer-left">
      <p class="footer-name">Wing Chun Leung</p>
      <p class="footer-tagline">Finance &middot; AI &middot; Hong Kong</p>
    </div>

    <div class="footer-links">
      <a href="mailto:wingchunleung8@gmail.com" class="footer-link" aria-label="Email">Email</a>
      <a href="https://linkedin.com/in/wingchunleung" class="footer-link" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">LinkedIn</a>
      <a href="https://github.com/wingchunleung" class="footer-link" target="_blank" rel="noopener noreferrer" aria-label="GitHub">GitHub</a>
    </div>

    <div class="footer-right">
      <button class="back-to-top" aria-label="Back to top" onclick="window.scrollTo({top:0,behavior:'smooth'})">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M8 14V2M2 8l6-6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <p class="footer-copy">
        <span class="seal-mark" aria-hidden="true">&#21360;</span>
        &copy; {year}
      </p>
    </div>
  </div>
</footer>

<style>
  /* Pre-footer CTA */
  .footer-cta {
    padding: clamp(4rem, 8vw, 8rem) 0;
    text-align: center;
    border-top: 1px solid var(--color-border);
  }

  .footer-cta-label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-wash);
    margin-bottom: var(--space-3);
  }

  .footer-cta-heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: var(--weight-light);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-6);
  }

  .footer-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: var(--weight-medium);
    padding: 16px 36px;
    background: var(--color-ink);
    color: var(--color-bg);
    border-radius: 100px;
    text-decoration: none;
    transition: all var(--duration-normal) var(--ease-out);
    min-height: 52px;
  }

  .footer-cta-btn::after { display: none; }

  .footer-cta-btn:hover {
    background: var(--color-vermillion);
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(199, 62, 29, 0.2);
  }

  .footer-cta-btn svg {
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .footer-cta-btn:hover svg {
    transform: translateX(4px);
  }

  /* Utility footer */
  .site-footer > .footer-content {
    padding: var(--space-6) 0;
    border-top: 1px solid var(--color-border);
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    text-align: center;
  }

  @media (min-width: 768px) {
    .footer-content {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: var(--weight-light);
  }

  .footer-tagline {
    font-size: var(--text-small);
    color: var(--color-wash);
  }

  .footer-links {
    display: flex;
    gap: var(--space-4);
  }

  .footer-link {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-wash);
    position: relative;
    text-decoration: none;
    transition: color var(--duration-normal) var(--ease-out);
  }

  .footer-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-vermillion);
    transition: width var(--duration-normal) ease-out;
  }

  .footer-link:hover {
    color: var(--color-text);
  }

  .footer-link:hover::after {
    width: 100%;
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  @media (min-width: 768px) {
    .footer-right { align-items: flex-end; }
  }

  .back-to-top {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-wash);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-out);
  }

  .back-to-top:hover {
    border-color: var(--color-vermillion);
    color: var(--color-vermillion);
    transform: translateY(-2px);
  }

  .footer-copy {
    font-size: var(--text-small);
    color: var(--color-wash);
  }

  .seal-mark {
    color: var(--color-vermillion);
    font-size: 1.25em;
    vertical-align: middle;
    margin-right: var(--space-1);
  }
</style>
