---
/**
 * IntroOverlay — Landing-page brand-moment animation
 *
 * ┌─────────────────────────────────────────────────────────────────────┐
 * │  THIS COMPONENT IS THE CANONICAL INTRO ANIMATION — DO NOT MODIFY    │
 * │  WITHOUT READING:                                                   │
 * │     1. CLAUDE.md  §"Deployment & Landing-Page Animation"            │
 * │     2. The plan at ~/.claude/plans/cozy-giggling-shore.md           │
 * │                                                                     │
 * │  The HTML, CSS, and JS in this file were extracted verbatim from   │
 * │  src/pages/index.astro to isolate the intro from accidental edits.  │
 * │  Edits here propagate to ALL pages that render <IntroOverlay />.    │
 * │                                                                     │
 * │  Three documented internal quirks (preserved on purpose):           │
 * │    • .intro-stage is defined twice on purpose (cascade is load-     │
 * │      bearing) — do not merge.                                       │
 * │    • The JS bypass branch hardcodes a hero-class list               │
 * │      (.hero-wave, .greeting-text, .hero-cta-wrap, .scroll-cue) —    │
 * │      this is a documented cross-component dependency on the hero    │
 * │      in src/pages/index.astro. Keep in sync if hero classes change. │
 * │    • prefers-reduced-motion hides the entire intro overlay.         │
 * │                                                                     │
 * │  HCI: Visceral — cinematic first impression creates emotional       │
 * │  engagement. Pinned canonical state matches gh-pages bf8a35c.       │
 * └─────────────────────────────────────────────────────────────────────┘
 */
---

<!-- ═══════════════════════════════════════════════════════════════════
     INTRO OVERLAY — The "brand moment" (plays once, then reveals hero)
     Separate layer above everything. Clip-path iris close reveals page.
     HCI: Visceral — cinematic first impression creates emotional engagement
     ═══════════════════════════════════════════════════════════════════ -->
<div class="intro-overlay" id="intro-overlay" aria-hidden="true">
  <div class="intro-bg"></div>
  <!-- Phase 1: DOM-based wow/eyes bombardment (CSS animated) -->
  <div class="wow-container" id="wowContainer"></div>
  <!-- Phase 2: Tease -->
  <div class="intro-tease" id="introTease">
    <span class="tease-text">see who this is</span>
  </div>
  <!-- Phase 3: Wave + Welcome -->
  <div class="intro-stage" id="introStage">
    <span class="intro-wave-emoji">👋</span>
    <span class="intro-welcome-text">Welcome to my site</span>
  </div>
</div>

<style is:global>
  /* ══════════════════════════════════════════════════════════════════════
     INTRO OVERLAY — Brand moment layer (plays once, reveals hero)
     ══════════════════════════════════════════════════════════════════════ */

  .intro-overlay {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    will-change: clip-path, opacity;
    clip-path: inset(0 0 0 0);
    animation: introExit 1s cubic-bezier(0.65, 0, 0.35, 1) 9s forwards;
  }

  .intro-overlay.finished { display: none; }

  .intro-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      #ffffff 0%,
      #faf9f7 30%,
      rgba(199, 62, 29, 0.03) 60%,
      #faf9f7 80%,
      #ffffff 100%
    );
    background-size: 200% 200%;
    animation: introGradientShift 4s ease-in-out infinite;
  }

  @keyframes introGradientShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .intro-stage {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  /* Wow/eyes bombardment container */
  .wow-container {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
    pointer-events: none;
  }

  .wow-particle {
    position: absolute;
    opacity: 0;
    will-change: transform, opacity;
    animation: wowFloat var(--dur, 3s) ease-out var(--delay, 0s) forwards;
    user-select: none;
    line-height: 1;
  }

  .wow-particle.is-text {
    font-weight: 900;
    font-family: var(--font-body);
    background: linear-gradient(135deg, #ff6b35, #e63946, #ff006e);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .wow-particle.is-emoji {
    font-family: "Apple Color Emoji", "Segoe UI Emoji", "Noto Color Emoji", sans-serif;
  }

  @keyframes wowFloat {
    0% {
      opacity: 0;
      transform: translate(0, 0) rotate(var(--rot-start, 0deg)) scale(0.3);
    }
    12% {
      opacity: 1;
      transform: translate(calc(var(--dx) * 0.1), calc(var(--dy) * 0.08)) rotate(calc(var(--rot-start, 0deg) + 5deg)) scale(1.15);
    }
    35% {
      opacity: 1;
      transform: translate(calc(var(--dx) * 0.4), calc(var(--dy) * 0.3)) rotate(calc(var(--rot-end, 15deg) * 0.5)) scale(var(--sc, 1));
    }
    70% {
      opacity: 0.6;
      transform: translate(calc(var(--dx) * 0.75), calc(var(--dy) * 0.7)) rotate(calc(var(--rot-end, 15deg) * 0.8)) scale(calc(var(--sc, 1) * 0.85));
    }
    100% {
      opacity: 0;
      transform: translate(var(--dx), var(--dy)) rotate(var(--rot-end, 15deg)) scale(0.4);
    }
  }

  /* Tease text */
  .intro-tease {
    position: relative;
    z-index: 2;
    opacity: 0;
  }

  .intro-tease.visible {
    opacity: 1;
    transition: opacity 0.5s ease-out;
  }

  .intro-tease.hidden {
    opacity: 0;
    transition: opacity 0.4s ease-out;
  }

  .tease-text {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: var(--weight-light);
    color: var(--color-wash);
    font-style: italic;
  }

  /* Wave + Welcome greeting (appears after tease) */
  .intro-stage {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    opacity: 0;
  }

  .intro-stage.visible {
    opacity: 1;
    transition: opacity 0.6s ease-out;
  }

  .intro-wave-emoji {
    display: inline-block;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    transform-origin: 70% 70%;
    opacity: 0;
    transform: scale(0.3);
  }

  .intro-wave-emoji.pop {
    animation: introWavePop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  .intro-wave-emoji.wave {
    animation: introWaveMotion 0.8s ease-in-out;
  }

  .intro-welcome-text {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: var(--weight-light);
    letter-spacing: -0.02em;
    color: var(--color-text);
    opacity: 0;
    transform: translateY(15px);
  }

  .intro-welcome-text.show {
    animation: introFinalText 0.7s ease-out forwards;
  }

  @keyframes introWavePop {
    0% { opacity: 0; transform: scale(0.3); }
    60% { opacity: 1; transform: scale(1.1); }
    100% { opacity: 1; transform: scale(1); }
  }

  @keyframes introWaveMotion {
    0% { transform: rotate(0deg); }
    15% { transform: rotate(14deg); }
    30% { transform: rotate(-8deg); }
    45% { transform: rotate(14deg); }
    60% { transform: rotate(-4deg); }
    75% { transform: rotate(10deg); }
    100% { transform: rotate(0deg); }
  }

  @keyframes introFinalText {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes introTextUp {
    from { transform: translateY(120%); }
    to { transform: translateY(0); }
  }

  @keyframes introExit {
    0% { clip-path: inset(0 0 0 0); opacity: 1; }
    60% { clip-path: inset(3% 3% 3% 3% round 24px); opacity: 1; }
    100% { clip-path: inset(50% 50% 50% 50% round 24px); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .intro-overlay { display: none; }
  }
</style>

<script>
  // ── Intro: DOM-based wow/eyes bombardment → wave greeting ──
  const overlay = document.getElementById('intro-overlay');
  const wowContainer = document.getElementById('wowContainer');
  const introStage = document.getElementById('introStage');

  if (overlay) {
    if (sessionStorage.getItem('intro-seen')) {
      overlay.remove();
      document.querySelectorAll('.hero-wave, .greeting-text, .hero-cta-wrap, .scroll-cue').forEach(el => {
        (el as HTMLElement).style.animation = 'none';
        (el as HTMLElement).style.opacity = '1';
        (el as HTMLElement).style.transform = 'none';
      });
    } else {
      sessionStorage.setItem('intro-seen', '1');

      const introTease = document.getElementById('introTease');

      // ── Phase 1: BIG wow/eyes particles filling the screen ──
      const TOTAL = 40; // fewer but BIGGER
      const SPAWN_WINDOW = 3500;
      let spawned = 0;

      function spawnWow() {
        if (!wowContainer || spawned >= TOTAL) return;
        const el = document.createElement('span');
        const isText = Math.random() > 0.35; // 65% wow, 35% 👀

        el.className = `wow-particle ${isText ? 'is-text' : 'is-emoji'}`;
        el.textContent = isText ? 'wow' : '👀';

        // Random position — fill the whole screen
        el.style.left = `${5 + Math.random() * 85}vw`;
        el.style.top = `${10 + Math.random() * 75}vh`;

        // MUCH bigger sizes — screen filling
        const size = isText ? (3 + Math.random() * 4) : (3.5 + Math.random() * 4.5);
        el.style.fontSize = `${size}rem`;

        el.style.setProperty('--dx', `${-80 + Math.random() * 160}px`);
        el.style.setProperty('--dy', `${-(100 + Math.random() * 200)}px`);
        el.style.setProperty('--rot-start', `${-20 + Math.random() * 40}deg`);
        el.style.setProperty('--rot-end', `${-30 + Math.random() * 60}deg`);
        el.style.setProperty('--sc', `${0.8 + Math.random() * 0.8}`);
        const dur = 3 + Math.random() * 2.5;
        el.style.setProperty('--dur', `${dur}s`);
        el.style.setProperty('--delay', '0s');

        wowContainer.appendChild(el);
        spawned++;
        setTimeout(() => el.remove(), dur * 1000 + 300);
      }

      // Burst: 10 big ones immediately
      for (let i = 0; i < 10; i++) {
        setTimeout(spawnWow, i * 40);
      }
      // Steady: rest over spawn window
      const remaining = TOTAL - 10;
      const interval = (SPAWN_WINDOW - 400) / remaining;
      for (let i = 0; i < remaining; i++) {
        setTimeout(spawnWow, 400 + i * interval);
      }

      // Phase 2: After 4.5s, fade particles → show "see who this is"
      setTimeout(() => {
        if (wowContainer) {
          wowContainer.style.transition = 'opacity 0.8s ease-out';
          wowContainer.style.opacity = '0';
        }
        setTimeout(() => {
          if (introTease) introTease.classList.add('visible');
        }, 600);
      }, 4500);

      // Phase 3: After 6.5s, hide tease → show wave greeting
      setTimeout(() => {
        if (introTease) introTease.classList.add('hidden');
        setTimeout(() => {
          if (introStage) {
            introStage.classList.add('visible');
            const waveEmoji = introStage.querySelector('.intro-wave-emoji');
            const welcomeText = introStage.querySelector('.intro-welcome-text');
            if (waveEmoji) {
              waveEmoji.classList.add('pop');
              setTimeout(() => waveEmoji.classList.add('wave'), 600);
            }
            if (welcomeText) {
              setTimeout(() => welcomeText.classList.add('show'), 300);
            }
          }
        }, 500);
      }, 6500);

      // Phase 3: Iris-close exit
      overlay.addEventListener('animationend', (e: AnimationEvent) => {
        if (e.animationName === 'introExit') {
          overlay.classList.add('finished');
          setTimeout(() => overlay.remove(), 200);
        }
      });
    }
  }
</script>
